local gifCache = {}

local function getImageCandidates(assetId)
	local num = tonumber(assetId)
	if not num then return {assetId} end
	-- Decal assets usually use image id = asset id + 1
	-- Image assets use the same id
	return {num + 1, num, num - 1}
end

local function applyWorkingImage(img, assetId)
	if not img or not img.Parent then return end
	local candidates = getImageCandidates(assetId)

	-- Try cached working id first
	if gifCache[tostring(assetId)] then
		img.Image = "rbxassetid://" .. gifCache[tostring(assetId)]
		return
	end

	-- Try each candidate and use first that loads
	task.spawn(function()
		for _, id in ipairs(candidates) do
			if not img or not img.Parent then return end
			img.Image = "rbxassetid://" .. id

			local attempts = 0
			while img and img.Parent and not img.IsLoaded and attempts < 15 do
				task.wait(0.06)
				attempts = attempts + 1
			end

			if img and img.Parent and img.IsLoaded then
				gifCache[tostring(assetId)] = tostring(id)
				return
			end
		end
	end)
end

