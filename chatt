    -- Glow расширяется вместе с окном
    TS:Create(MFGlow, TweenInfo.new(0.55, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, 0, 0.45, 0),
        Size = UDim2.new(0, 660, 0, 380),
        BackgroundTransparency = 0.92
    }):Play()

    -- Анимируем скругление
    TS:Create(MFCorner, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        CornerRadius = UDim.new(0, 14)
    }):Play()

    -- Фон чата проявляется
    TS:Create(ChatBG, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        ImageTransparency = 0.86
    }):Play()

    -- Содержимое появляется чуть позже, чтобы окно успело раскрыться
    task.delay(0.18, function()
        if not chatOpen then return end
        TS:Create(ChatContent, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            GroupTransparency = 0
        }):Play()

        -- Элементы выезжают на свои места с красивым bounce
        TS:Create(HD, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = normalPositions.HD
        }):Play()
        TS:Create(BB, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = normalPositions.BB
        }):Play()
        TS:Create(CL, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = normalPositions.CL
        }):Play()
        TS:Create(ChannelsPanel, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Position = normalPositions.ChannelsPanel
        }):Play()
        TS:Create(RS, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Position = normalPositions.RS
        }):Play()
    end)

    task.delay(0.7, function()
        chatAnimating = false
    end)
end

local function animateChatClose()
    if chatAnimating then return end
    chatAnimating = true
    chatOpen = false
    lastChatSize = MF.Size

    -- Сначала убираем содержимое
    TS:Create(ChatContent, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        GroupTransparency = 1
    }):Play()

    TS:Create(ChatBG, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        ImageTransparency = 1
    }):Play()

    -- Элементы уезжают
    TS:Create(HD, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Position = hiddenPositions.HD
    }):Play()
    TS:Create(BB, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Position = hiddenPositions.BB
    }):Play()
    TS:Create(CL, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Position = hiddenPositions.CL
    }):Play()
    TS:Create(ChannelsPanel, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Position = hiddenPositions.ChannelsPanel
    }):Play()

    task.delay(0.15, function()
        -- Окно и glow сворачиваются обратно в кнопку
        local closeTween = TS:Create(MF, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Position = MB_CENTER_POS,
            Size = MB_SIZE,
            BackgroundTransparency = 0
        })
        closeTween:Play()

        TS:Create(MFCorner, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            CornerRadius = UDim.new(1, 0)
        }):Play()

        TS:Create(MFGlow, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Position = MB_CENTER_POS + UDim2.new(0, -10, 0, -10),
            Size = UDim2.new(0, 80, 0, 80),
            BackgroundTransparency = 1
        }):Play()

        closeTween.Completed:Connect(function()
            MF.Visible = false
            MFGlow.Visible = false
            MB.Visible = true
            MBGlow.Visible = true
            chatAnimating = false
        end)
    end)
end

local function toggleChat()
    if chatOpen then
        animateChatClose()
    else
        animateChatOpen()
    end
end

