task.spawn(function()
	if not req then
		drawMessage("SYSTEM", "HTTP request не найден", Color3.fromRGB(255, 80, 80), "sq", "none", "none", true, false, false, false, "", "global")
		return
	end

	while UI.SG.Parent do
		local msgUrl = API_URL .. "/messages?after=" .. State.lastId
		if State.activeChannel then
			msgUrl = msgUrl .. "&channel=" .. State.activeChannel
			if State.activeChannel == "local" then
				msgUrl = msgUrl .. "&server_id=" .. tostring(game.JobId or "")
			end
		end
		local ok, res = pcall(req, {Url = msgUrl, Method = "GET", Headers = GET_HEADERS})
		if ok and res and res.StatusCode == 200 then
			if State.firstPoll then drawMessage("SYSTEM", "Подключено к серверу!", Color3.fromRGB(0, 255, 110), "sq", "none", "none", true, false, false, false, "", "global") end

			local ok2, msgs = pcall(Services.HTTP.JSONDecode, Services.HTTP, res.Body)
			if ok2 and type(msgs) == "table" then
				for _, m in ipairs(msgs) do
					if type(m) == "table" and m.id then
						State.lastId = math.max(State.lastId, m.id)
						local key = tostring(m.name or "") .. "|" .. tostring(m.text or "")
						local pendingTime = State.pendingLocal[key]
						if not State.myIds[m.id] and not (pendingTime and (tick() - pendingTime < 5)) then
							local pmTarget, pmPayload = parsePMText(m.text)
							if pmTarget then
								handleIncoming(m)
							else
								local mChan = m.channel or "global"
								local name, text, color, st = tostring(m.name or "Anon"), tostring(m.text or ""), parseColor(m.color), unpackMeta(m.meta)
								local replyData = m.reply_to and {id = m.reply_to, name = m.reply_name or "", text = m.reply_text or ""} or nil
								drawMessage(name, text, color, st.bs, st.fx, st.mf, st.b, st.i, st.u, st.s, st.gn, mChan, m.id, replyData, m.reactions, m.edited)
							end
						end
					end
				end
			end
		elseif State.firstPoll then
			drawMessage("SYSTEM", "Сервер недоступен. Проверь API_URL.", Color3.fromRGB(255, 70, 70), "sq", "none", "none", true, false, false, false, "", "global")
		end

		pcall(function()
			local okT, resT = req({Url = API_URL .. "/typing?channel=" .. State.activeChannel, Method = "GET", Headers = GET_HEADERS})
			if okT and resT and resT.StatusCode == 200 then
				local okT2, list = pcall(Services.HTTP.JSONDecode, Services.HTTP, resT.Body)
				if okT2 and type(list) == "table" then
					State.typingUsers = {}
					for _, n in ipairs(list) do
						if n:lower() ~= LP.Name:lower() then State.typingUsers[n] = tick() end
					end
					updateTyping()
				end
			end
		end)

		pcall(function()
			local okC, resC = req({Url = API_URL .. "/channels", Method = "GET", Headers = GET_HEADERS})
			if okC and resC and resC.StatusCode == 200 then
				local okC2, list = pcall(Services.HTTP.JSONDecode, Services.HTTP, resC.Body)
				if okC2 and type(list) == "table" then
					local temp = {"global", "local"}
					for _, ch in ipairs(list) do
						if ch ~= "global" and ch ~= "local" then table.insert(temp, ch) end
					end
					State.channelsList = temp
					refreshChannelsList()
				end
			end
		end)

		pcall(function()
			local okP, resP = req({Url = API_URL .. "/pins?channel=" .. State.activeChannel, Method = "GET", Headers = GET_HEADERS})
			if okP and resP and resP.StatusCode == 200 then
				local okP2, list = pcall(Services.HTTP.JSONDecode, Services.HTTP, resP.Body)
				if okP2 and type(list) == "table" and #list > 0 then
					local pin = list[#list]
					if pin.text and pin.text ~= UI.PinLabel.Text then
						UI.PinBar.Visible = true
						Services.TS:Create(UI.PinBar, Tween.Fast, {Size = UDim2.new(1, -148, 0, 34)}):Play()
						UI.PinLabel.Text = "📌 " .. escapeRich(pin.text):sub(1, 80)
					end
				end
			end
		end)

		State.firstPoll = false
		task.wait(1.4)
	end
end)

