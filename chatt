local function buildEffectGrid(parent, items, selectedVar, callback, yStart)
	local grid = Instance.new("Frame", parent)
	grid.Size = UDim2.new(1, -20, 1, -yStart)
	grid.Position = UDim2.new(0, 10, 0, yStart)
	grid.BackgroundTransparency = 1
	local layout = Instance.new("UIGridLayout", grid)
	layout.CellSize = UDim2.new(0, 100, 0, 34)
	layout.CellPadding = UDim2.new(0, 8, 0, 8)
	layout.SortOrder = Enum.SortOrder.LayoutOrder

	local buttons = {}
	for _, item in ipairs(items) do
		local id, label = item[1], item[2]
		local b = Instance.new("TextButton", grid)
		b.Size = UDim2.new(0, 100, 0, 34)
		b.BackgroundColor3 = (selectedVar == id) and State.col or Color3.fromRGB(35, 35, 45)
		b.Text = label
		b.TextColor3 = (selectedVar == id) and Color3.new(0,0,0) or Color3.new(1,1,1)
		b.Font = Enum.Font.GothamBold
		b.TextSize = 10
		b.AutoButtonColor = false
		Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
		table.insert(buttons, {b, id})
		b.MouseButton1Click:Connect(function()
			selectedVar = callback(id)
			for _, pair in ipairs(buttons) do
				pair[1].BackgroundColor3 = (selectedVar == pair[2]) and State.col or Color3.fromRGB(35, 35, 45)
				pair[1].TextColor3 = (selectedVar == pair[2]) and Color3.new(0,0,0) or Color3.new(1,1,1)
			end
		end)
	end
	return grid
end

