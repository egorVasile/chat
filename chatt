local function handleIncoming(m)
	local target, payload = parsePMText(m.text)
	if not target then return end
	if target:lower() ~= LP.Name:lower() then return end

	local sender = safeName(m.name)
	local senderColor = rgbString(parseColor(m.color))
	ensureDM(sender)
	table.insert(State.dmHistory[sender], {from = sender, text = payload, color = senderColor})
	if #State.dmHistory[sender] > MAX_PM_MESSAGES then table.remove(State.dmHistory[sender], 1) end
	saveJSON("dms", State.dmHistory)

	if State.activeDM == sender then
		drawPMBubble(sender, payload, senderColor, false)
	else
		State.dmUnread[sender] = (State.dmUnread[sender] or 0) + 1
		updateBadge()
		showNotification("Новое ЛС", "От " .. sender, "💬")
	end
	refreshDMList()
end

