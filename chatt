local escapeRich = function(s) return s:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;") end
local req = (syn and syn.request) or (http and http.request) or http_request or request
local myIds = {}

function drawMessage(uName, text, nColor, nStyle, nFx, mStyleFx, wB, wI, wU, senderGame)
    local frames = {}
    for _, c in ipairs(CL:GetChildren()) do if c:IsA("Frame") then table.insert(frames, c) end end
    if #frames >= MAX_MESSAGES then frames[1]:Destroy() end

    local mf = Instance.new("Frame", CL)
    mf.BackgroundTransparency = 1
    mf.Size = UDim2.new(1, 0, 0, 24)
    Instance.new("UICorner", mf).CornerRadius = UDim.new(0, 4)
    
    -- Обработка ПКМ для Контекстного Меню
    mf.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            local tw = TS:Create(mf, TweenInfo.new(0.2), {BackgroundTransparency = 0.8, BackgroundColor3 = Color3.new(1,1,1)})
            tw:Play()
            task.delay(1, function() TS:Create(mf, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play() end)
            
            selectedUser = uName:gsub("%[.-%] ", ""):gsub("👑 СОЗДАТЕЛЬ ", "")
            CMenu.Position = UDim2.new(0, UIS:GetMouseLocation().X, 0, UIS:GetMouseLocation().Y)
            CMenu.Visible = true
        end
    end)

    mf.Position = UDim2.new(0, -50, 0, 0)
    local cg = Instance.new("CanvasGroup", mf)
    cg.Size = UDim2.new(1, 0, 1, 0)
    cg.BackgroundTransparency = 1
    cg.GroupTransparency = 1
    
    TS:Create(mf, tweenInfoBounce, {Position = UDim2.new(0, 0, 0, 0)}):Play()
    TS:Create(cg, tweenInfoFast, {GroupTransparency = 0}):Play()

    local nl = Instance.new("TextLabel", cg)
    nl.Size = UDim2.new(0, 200, 0, 24)
    nl.BackgroundTransparency = 1
    nl.Font = Enum.Font.GothamBold
    nl.TextSize = 13
    nl.TextXAlignment = Enum.TextXAlignment.Left
    nl.TextColor3 = nColor
    
    local tN = uName
    local role = ROLES[uName]
    if nStyle == "sq" then tN = "[" .. tN .. "]" elseif nStyle == "round" then tN = "(" .. tN .. ")" elseif nStyle == "ang" then tN = "<" .. tN .. ">" end
    if role then tN = role.tag .. " " .. tN nColor = role.color nl.TextColor3 = nColor nFx = role.effect ~= "none" and role.effect or nFx end
    
    local gameTag = (senderGame and senderGame ~= "" and senderGame ~= "Roblox") and "["..senderGame.."] " or ""
    nl.Text = os.date("%H:%M") .. " " .. gameTag .. tN

    local off = 0
    task.spawn(function() task.wait() off = nl.TextBounds.X + 8 end)

    if nFx == "rbw" then task.spawn(function() while nl.Parent do nl.TextColor3 = Color3.fromHSV((tick()%3)/3, 1, 1) task.wait() end end)
    elseif nFx == "gnk" then task.spawn(function() while nl.Parent do if math.random(1,10)>8 then nl.Position=UDim2.new(0,math.random(-2,2),0,math.random(-2,2)) nl.TextColor3=Color3.new(1,0,0) task.wait(0.05) nl.TextColor3=Color3.new(0,1,1) task.wait(0.05) nl.TextColor3=nColor nl.Position=UDim2.new(0,0,0,0) end task.wait(0.1) end end)
    elseif nFx == "pls" then task.spawn(function() while nl.Parent do nl.TextTransparency = 0.3 + 0.4 * math.sin(tick() * 3) task.wait() end end) end

    local gifId = string.match(text, "^%[gif=(%d+)%]$")
    if gifId then
        local img = Instance.new("ImageLabel", cg)
        task.defer(function() img.Position = UDim2.new(0, off, 0, 0) end)
        img.Size = UDim2.new(0, 80, 0, 80)
        img.BackgroundTransparency = 1
        img.Image = "rbxassetid://" .. gifId
        img.ScaleType = Enum.ScaleType.Fit
        mf.Size = UDim2.new(1, 0, 0, 85)
    else
        local tl = Instance.new("TextLabel", cg)
        task.defer(function() tl.Position, tl.Size = UDim2.new(0, off, 0, 0), UDim2.new(1, -off, 0, 24) end)
        tl.BackgroundTransparency = 1
        tl.Font = Enum.Font.Gotham
        tl.TextSize = 13
        tl.TextXAlignment = Enum.TextXAlignment.Left
        tl.TextYAlignment = Enum.TextYAlignment.Top
        tl.RichText = true
        tl.TextWrapped = true
        
        local str = escapeRich(text)
        
        -- Логика упоминаний @Имя
        local myName = string.lower(LP.Name)
        if string.find(string.lower(str), "@" .. myName) then
            str = string.gsub(str, "@" .. LP.Name, '<font color="rgb(255,100,100)"><b>@' .. LP.Name .. '</b></font>')
            if uName ~= LP.Name then showNotification("Новое упоминание", uName .. " упомянул вас в чате!") end
        end

        if wB then str = "<b>" .. str .. "</b>" end if wI then str = "<i>" .. str .. "</i>" end if wU then str = "<u>" .. str .. "</u>" end
        tl.Text = str
        tl.TextColor3 = Color3.fromRGB(240, 240, 245)

        task.defer(function() if tl.Parent then local h = math.max(24, tl.TextBounds.Y) tl.Size = UDim2.new(1, -off, 0, h) mf.Size = UDim2.new(1, 0, 0, h) cg.Size = mf.Size end end)

        if mStyleFx == "shk" then task.spawn(function() while tl.Parent do tl.Position=UDim2.new(0,off+math.random(-1,1),0,math.random(-1,1)) task.wait(0.03) end end)
        elseif mStyleFx == "glch" then task.spawn(function() while tl.Parent do if math.random(1,20)>18 then tl.TextTransparency=0.5 tl.Position=UDim2.new(0,off+math.random(-3,3),0,math.random(-2,2)) task.wait(0.05) tl.TextTransparency=0 tl.Position=UDim2.new(0,off,0,0) end task.wait(0.1) end end)
        elseif mStyleFx == "neon" then local stk = Instance.new("UIStroke", tl) stk.Color = nColor stk.Thickness = 1.5 task.spawn(function() while tl.Parent do stk.Transparency = 0.2 + 0.6 * math.abs(math.sin(tick() * 2)) task.wait() end end)
        elseif mStyleFx == "mrbw" then task.spawn(function() while tl.Parent do tl.TextColor3 = Color3.fromHSV((tick()%3)/3, 0.6, 1) task.wait() end end) end
    end
end

-- ===================== СЕТЬ И ВЗАИМОДЕЙСТВИЕ =====================
local function sendPayload(textData)
    if not req then return end
    local metaStr = string.format("bs=%s;fx=%s;mf=%s;b=%d;i=%d;u=%d;gn=%s", bStyle, fx, msgFx, isB and 1 or 0, isI and 1 or 0, isU and 1 or 0, myGameName)
    local body = HTTP:JSONEncode({ name = LP.Name, text = textData, color = string.format("%d,%d,%d", math.floor(col.R * 255), math.floor(col.G * 255), math.floor(col.B * 255)), meta = metaStr })
    task.spawn(function()
        local ok, res = pcall(req, { Url = API_URL .. "/send", Method = "POST", Headers = {["Content-Type"]="application/json"}, Body = body })
        if ok and res and res.StatusCode == 200 then local _, data = pcall(HTTP.JSONDecode, HTTP, res.Body) if data and data.id then myIds[data.id] = true end end
    end)
end

