local function isPress(i) return i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch end
local function isRightClick(i) return i.UserInputType == Enum.UserInputType.MouseButton2 end
local function isMove(i) return i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch end
local function escapeRich(s) return tostring(s or ""):gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;") end
local function pointIn(gui, mPos) local p, s = gui.AbsolutePosition, gui.AbsoluteSize return mPos.X >= p.X and mPos.X <= p.X + s.X and mPos.Y >= p.Y and mPos.Y <= p.Y + s.Y end
local function parseColor(str)
    local r,g,b = tostring(str or ""):match("(%d+),(%d+),(%d+)")
    if r then return Color3.fromRGB(math.clamp(tonumber(r) or 255,0,255), math.clamp(tonumber(g) or 255,0,255), math.clamp(tonumber(b) or 255,0,255)) end
    return Color3.new(1,1,1)
end
local function rgbString(c) return string.format("%d,%d,%d", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255)) end
local function safeName(n) n = tostring(n or "Anon"):gsub("[^%w_]", "") if n=="" then n="Anon" end return n:sub(1,24) end
local function makePMText(tgt, pay) return "[PM:" .. safeName(tgt) .. "]" .. tostring(pay or "") end
local function parsePMText(t) return tostring(t or ""):match("^%[PM:([%w_]+)%](.*)$") end
local function isGifText(t) return tostring(t or ""):match("^%[gif=(%d+)%]$") end

