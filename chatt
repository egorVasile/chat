    tl.Font = Enum.Font.Gotham
    tl.TextSize = 13
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.TextYAlignment = Enum.TextYAlignment.Top
    tl.RichText = true
    tl.TextWrapped = true -- [NEW] длинные сообщения переносятся, а не обрезаются

    -- [FIX] в оригинале RichText-теги потерялись (str=''..str..'') — форматирование не работало вообще
    local str = escapeRich(text)
    if wB then str = "<b>" .. str .. "</b>" end
    if wI then str = "<i>" .. str .. "</i>" end
    if wU then str = "<u>" .. str .. "</u>" end
    if wS then str = "<s>" .. str .. "</s>" end
    tl.Text = str
    tl.TextColor3 = Color3.fromRGB(240, 240, 245)

    -- [NEW] авто-высота под многострочный текст
    task.defer(function()
        if tl.Parent then
            local h = math.max(24, tl.TextBounds.Y)
            tl.Size = UDim2.new(1, -off, 0, h)
            mf.Size = UDim2.new(1, 0, 0, h)
