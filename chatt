-- [NEW] экранирование, чтобы < > & в тексте не ломали RichText
local function escapeRich(s)
    return s:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;")
end

local function drawMessage(uName, text, nColor, nStyle, nFx, mStyleFx, wB, wI, wU, wS)
    -- [NEW] лимит сообщений — самые старые удаляются
    local frames = {}
    for _, c in ipairs(CL:GetChildren()) do
        if c:IsA("Frame") then table.insert(frames, c) end
    end
    if #frames >= MAX_MESSAGES then
        frames[1]:Destroy()
    end

    local mf = Instance.new("Frame", CL)
    mf.BackgroundTransparency = 1
    mf.Size = UDim2.new(1, 0, 0, 24)

    local nl = Instance.new("TextLabel", mf)
    nl.Size = UDim2.new(0, 150, 0, 24)
    nl.BackgroundTransparency = 1
    nl.Font = Enum.Font.GothamBold
    nl.TextSize = 13
    nl.TextXAlignment = Enum.TextXAlignment.Left

    local tN = uName
    if nStyle == "sq" then tN = "[" .. tN .. "]"
    elseif nStyle == "round" then tN = "(" .. tN .. ")"
    elseif nStyle == "ang" then tN = "<" .. tN .. ">" end
    -- [NEW] время сообщения
    tN = os.date("%H:%M") .. " " .. tN
    nl.Text = tN

    if nFx == "rbw" then
        task.spawn(function()
            while nl.Parent do
                for h = 0, 1, 0.01 do
                    if not nl.Parent then break end
                    nl.TextColor3 = Color3.fromHSV(h, 1, 1)
                    task.wait(0.02)
                end
            end
        end)
    elseif nFx == "gnk" then
        nl.TextColor3 = nColor
        task.spawn(function()
            while nl.Parent do
                local sqs = {}
                for _ = 1, math.random(1, 2) do
                    local sq = Instance.new("Frame", nl)
                    sq.BorderSizePixel = 0
                    sq.BackgroundColor3 = math.random() < 0.5 and Color3.fromRGB(170, 0, 255) or Color3.new(0, 0, 0)
                    sq.Size = UDim2.new(0, math.random(3, 8), 0, math.random(3, 8))
                    sq.Position = UDim2.new(0, math.random(0, math.max(1, math.floor(nl.TextBounds.X))), 0, math.random(0, 12))
                    table.insert(sqs, sq)
                end
                task.wait(0.08)
                for _, q in ipairs(sqs) do q:Destroy() end
                task.wait(0.1)
            end
        end)
    else
        nl.TextColor3 = nColor
    end

    local off = nl.TextBounds.X + 8
    local tl = Instance.new("TextLabel", mf)
    tl.Position = UDim2.new(0, off, 0, 0)
    tl.Size = UDim2.new(1, -off, 0, 24)
