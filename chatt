		task.delay(0.3, function()
			SettingsGroup.Visible = false
			CL.Visible = false
			ChannelsPanel.Visible = false
			BB.Visible = true
			GF.Visible = true
			GF.Position = UDim2.new(-1, 0, 0, 50)
			TS:Create(BB, tweenSmooth, {Position = UDim2.new(0, 0, 1, -58)}):Play()
			TS:Create(GF, tweenSmooth, {Position = UDim2.new(0, 12, 0, 50)}):Play()
