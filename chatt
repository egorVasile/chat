--// ===================== GIF RESOLVER =====================
local gifCache = {}
local function resolveImageId(assetId)
	assetId = tostring(assetId)
	if gifCache[assetId] then return gifCache[assetId] end
	local num = tonumber(assetId)
	if not num then gifCache[assetId] = assetId; return assetId end

	if req then
		local ok, res = pcall(req, {
			Url = API_URL .. "/resolve-image/" .. assetId,
			Method = "GET",
			Headers = GET_HEADERS
		})
		if ok and res and res.StatusCode == 200 then
			local ok2, data = pcall(HTTP.JSONDecode, HTTP, res.Body)
			if ok2 and data and data.image_id then
				gifCache[assetId] = tostring(data.image_id)
				return gifCache[assetId]
			end
		end
	end

	local ok, model = pcall(function() return InsertService:LoadAsset(num) end)
	if ok and model then
		local found = nil
		for _, desc in ipairs(model:GetDescendants()) do
			if desc:IsA("Decal") or desc:IsA("Texture") then
				local tex = desc.Texture
				local id = tex and tex:match("%d+")
				if id then found = id; break end
			end
		end
		model:Destroy()
		if found then gifCache[assetId] = found; return found end
	end

	gifCache[assetId] = assetId
	return assetId
end

