local function updateColorWheel(input)
	local cx, cy = CW.AbsolutePosition.X + CW.AbsoluteSize.X/2, CW.AbsolutePosition.Y + CW.AbsoluteSize.Y/2
	local dx, dy = input.Position.X - cx, input.Position.Y - cy
	local dist, maxR = math.sqrt(dx*dx + dy*dy), 50
	if dist > maxR then dx, dy, dist = (dx/dist)*maxR, (dy/dist)*maxR, maxR end
	dot.Position = UDim2.new(0, dx + maxR, 0, dy + maxR)
	local hue = math.atan(dy, dx) / (math.pi * 2)
	if hue < 0 then hue = hue + 1 end
	col = Color3.fromHSV(hue, clamp(dist/maxR, 0, 1), 1)
	prv.BackgroundColor3 = col
	updateAccent()
	saveJSON("settings", {col = rgbString(col), fx = fx, msgFx = msgFx, bStyle = bStyle, winTrans = windowTransparency, bgTrans = bgTransparency, myStatus = myStatus})
end

