--// ===================== GIF DECAL -> IMAGE RESOLVER =====================
local gifCache = {}
local function resolveImageId(assetId)
    assetId = tostring(assetId)
    if gifCache[assetId] then return gifCache[assetId] end
    local num = tonumber(assetId)
    if not num then
        gifCache[assetId] = assetId
        return assetId
    end

    -- Метод 1: через наш сервер (Roblox AssetDelivery API)
    if req then
        local ok, res = pcall(req, {
            Url = API_URL .. "/resolve-image/" .. assetId,
            Method = "GET",
            Headers = GET_HEADERS
        })
        if ok and res and res.StatusCode == 200 then
            local ok2, data = pcall(HTTP.JSONDecode, HTTP, res.Body)
            if ok2 and data and data.image_id then
                gifCache[assetId] = tostring(data.image_id)
                return gifCache[assetId]
            end
        end
    end

    -- Метод 2: fallback через InsertService (может не работать в некоторых играх)
    local ok, model = pcall(function()
        return InsertService:LoadAsset(num)
    end)

    if ok and model then
        local found = nil
        for _, desc in ipairs(model:GetDescendants()) do
            if desc:IsA("Decal") or desc:IsA("Texture") then
                local tex = desc.Texture
                local id = tex and tex:match("%d+")
                if id then
                    found = id
                    break
                end
            end
        end
        model:Destroy()
        if found then
            gifCache[assetId] = found
            return found
        end
    end

    gifCache[assetId] = assetId
    return assetId
end

--// ===================== DRAW GLOBAL MESSAGE DIRECT =====================
local function drawMessageDirect(uName, text, nColor, nStyle, nFx, mStyleFx, wB, wI, wU, wS, senderGame)
    uName, text = tostring(uName or "Anon"), tostring(text or "")

    local frames = {}
    for _, c in ipairs(CL:GetChildren()) do
        if c:IsA("Frame") then table.insert(frames, c) end
    end
    if #frames >= MAX_MESSAGES then frames[1]:Destroy() end

    local isGif = isGifText(text)
    local frameHeight = isGif and 96 or 26

    local mf = Instance.new("Frame")
    mf.Name = "Message_" .. uName
    mf.BackgroundTransparency = 1
    mf.Size = UDim2.new(1, 0, 0, frameHeight)
    mf.ClipsDescendants = false
    mf.Parent = CL
    Instance.new("UICorner", mf).CornerRadius = UDim.new(0, 6)

    mf.InputBegan:Connect(function(input)
        if isRightClick(input) and uName ~= "SYSTEM" then
            selectedUser = safeName(uName)
            TS:Create(mf, TweenInfo.new(0.12), {BackgroundTransparency=0.78, BackgroundColor3=Color3.fromRGB(180,180,190)}):Play()
            task.delay(0.6, function()
                if mf.Parent then
                    TS:Create(mf, TweenInfo.new(0.25), {BackgroundTransparency=1}):Play()
                end
            end)
            local mouse = UIS:GetMouseLocation()
            CMenu.Position = UDim2.new(0, mouse.X+4, 0, mouse.Y+4)
            CTitle.Text = "Игрок использует скрипт"
            CTitle.TextColor3 = Color3.fromRGB(90,255,150)
            CMenu.Visible = true
        end
    end)

    mf.Position = UDim2.new(0, -45, 0, 0)
    local cg = Instance.new("CanvasGroup")
    cg.Size = UDim2.new(1, 0, 1, 0)
    cg.BackgroundTransparency = 1
    cg.GroupTransparency = 1
    cg.Parent = mf

    TS:Create(mf, tweenSoft, {Position=UDim2.new(0,0,0,0)}):Play()
    TS:Create(cg, tweenSoft, {GroupTransparency=0}):Play()

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0, 260, 0, 24)
    nameLabel.Position = UDim2.new(0, 0, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 13
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.TextColor3 = nColor
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    nameLabel.RichText = false
    nameLabel.Parent = cg

    local displayName = uName
    if nStyle == "sq" then
        displayName = "[" .. displayName .. "]"
    elseif nStyle == "round" then
        displayName = "(" .. displayName .. ")"
    elseif nStyle == "ang" then
        displayName = "<" .. displayName .. ">"
    elseif nStyle == "curly" then
        displayName = "{" .. displayName .. "}"
    end

    local role = ROLES[uName]
    if role then
        displayName = role.tag .. " " .. displayName
        nColor = role.color
        nameLabel.TextColor3 = role.color
        if role.effect and role.effect ~= "none" then nFx = role.effect end
    end

    local gameTag = (senderGame and senderGame ~= "" and senderGame ~= "Roblox") and ("[" .. senderGame .. "] ") or ""
    nameLabel.Text = os.date("%H:%M") .. " " .. gameTag .. displayName

    applyNameEffect(nameLabel, mf, nFx, nColor)

    if isGif then
        local contentOffset = math.clamp(nameLabel.TextBounds.X + 8, 110, math.max(120, CL.AbsoluteSize.X - 140))
        local img = Instance.new("ImageLabel")
        img.Position = UDim2.new(0, contentOffset, 0, 4)
        img.Size = UDim2.new(0, 84, 0, 84)
        img.BackgroundTransparency = 1
        img.Image = "rbxassetid://" .. isGif
        img.ScaleType = Enum.ScaleType.Fit
        img.ZIndex = 10
        img.Parent = cg

        task.spawn(function()
            local resolved = resolveImageId(isGif)
            if img and img.Parent then
                img.Image = "rbxassetid://" .. resolved
            end
        end)
        return
    end

    local textLabel = Instance.new("TextLabel")
    textLabel.BackgroundTransparency = 1
    textLabel.Font = Enum.Font.Gotham
    textLabel.TextSize = 13
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.TextYAlignment = Enum.TextYAlignment.Top
    textLabel.RichText = true
    textLabel.TextWrapped = true
    textLabel.TextColor3 = Color3.fromRGB(240,240,248)
    textLabel.Parent = cg

    local str = escapeRich(text)
    local lowerStr = string.lower(str)
    local lowerName = string.lower(LP.Name)
    local sIdx, eIdx = lowerStr:find("@" .. lowerName, 1, true)
    if sIdx then
        local actualMention = str:sub(sIdx, eIdx)
        str = str:sub(1, sIdx-1) .. '<font color="rgb(255,100,100)"><b>' .. actualMention .. '</b></font>' .. str:sub(eIdx+1)
        if uName ~= LP.Name then
            showNotification("Упоминание", uName .. " упомянул вас")
        end
    end
    if wB then str = "<b>" .. str .. "</b>" end
    if wI then str = "<i>" .. str .. "</i>" end
    if wU then str = "<u>" .. str .. "</u>" end
