--// ===================== DYNAMIC COOLDOWN SYSTEM =====================
local currentCooldown = 0
local cooldownLevel = 0
local lastMessageTime = 0
local lastMessageText = ""

local function cleanText(t) return tostring(t):lower():gsub("[%s%p]", "") end
local function isSpam(t1, t2)
    local c1, c2 = cleanText(t1), cleanText(t2)
    if c1 == c2 then return true end
    if #c1 > 0 and #c2 > 0 then
        if c1:find(c2, 1, true) or c2:find(c1, 1, true) then
            if math.abs(#c1 - #c2) <= 3 then return true end
        end
    end
    return false
end

local function checkCooldown(text)
    local now = tick()
    local timeDiff = now - lastMessageTime
    local spamDetected = isSpam(text, lastMessageText)

    if now < lastMessageTime + currentCooldown then
        showNotification("Ограничение", "Подожди еще " .. math.ceil((lastMessageTime + currentCooldown) - now) .. " сек.")
        return false
    end

    local expiry = lastMessageTime + currentCooldown
    if now > expiry then
        local idleTime = now - expiry
        local decayAmount = math.floor(idleTime / 4)
        cooldownLevel = math.max(0, cooldownLevel - decayAmount)
    end

    if timeDiff < 0.8 then
        cooldownLevel = 1
        currentCooldown = 1
        showNotification("Анти-Спам", "Кулдаун: 1 сек. (Быстрая отправка)")
    elseif spamDetected and timeDiff < 3.0 then
        cooldownLevel = 2
        currentCooldown = 5
        showNotification("Анти-Спам", "Кулдаун: 5 сек. (Спам/Дублирование)")
    else
        currentCooldown = cooldownLevel == 2 and 5 or (cooldownLevel == 1 and 1 or 0)
    end

    lastMessageTime = now
    lastMessageText = text
    return true
end

--// ===================== PRESENCE DOT SYSTEM =====================
local function updatePlayerDot(player)
    if not player then return end
    local char = player.Character or player.CharacterAdded:Wait()
    if not char then return end
    local head = char:WaitForChild("Head", 6)
    if not head then return end

    local oldDot = head:FindFirstChild("NeonPresenceDot")
    if oldDot then oldDot:Destroy() end

    local bgui = Instance.new("BillboardGui", head)
    bgui.Name = "NeonPresenceDot"
    bgui.Size = UDim2.new(0, 11, 0, 11)
    bgui.StudsOffset = Vector3.new(0, 2.4, 0)
    bgui.AlwaysOnTop = true

    local dotFrame = Instance.new("Frame", bgui)
    dotFrame.Size = UDim2.new(1, 0, 1, 0)
    Instance.new("UICorner", dotFrame).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", dotFrame).Color = Color3.fromRGB(0,0,0)

    local function refreshColor()
        if not player or not player.Parent then return end
        local hasScript = player:GetAttribute("HasNeonScript")
        dotFrame.BackgroundColor3 = hasScript and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 50, 50)
    end
    refreshColor()

    local connection
    connection = player:GetAttributeChangedSignal("HasNeonScript"):Connect(function()
        if not bgui or not bgui.Parent then
            connection:Disconnect()
            return
        end
        refreshColor()
    end)
end

