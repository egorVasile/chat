local lastId, firstPoll = 0, true

-- Проверка связи с сервером при старте
task.spawn(function()
    if not req then
        warn("[NeonChat] request не найден. Смени эксплойт.")
        return
    end
    task.wait(2)

    -- Сначала проверяем health
    local ok, res = pcall(req, {Url = API_URL .. "/health", Method = "GET", Headers = GET_HEADERS})
    if ok and res then
        print("[NeonChat] /health статус:", res.StatusCode, "тело:", tostring(res.Body):sub(1, 100))
        if res.StatusCode ~= 200 then
            showNotification("Сервер", "Сервер ответил кодом " .. tostring(res.StatusCode) .. ". Проверь API_URL/версию сервера.")
            return
        end
    else
        warn("[NeonChat] /health ошибка:", tostring(res))
        showNotification("Сервер", "Не удалось связаться с сервером. Проверь API_URL.")
        return
    end

    -- Регистрируем клиента: получаем challenge, решаем и отправляем
    local challengeOk, challengeRes = pcall(req, {Url = API_URL .. "/challenge", Method = "GET", Headers = GET_HEADERS})
    if challengeOk and challengeRes and challengeRes.StatusCode == 200 then
        local ok2, challengeData = pcall(HTTP.JSONDecode, HTTP, challengeRes.Body)
        if ok2 and challengeData and challengeData.question and challengeData.token then
            local registerBody = HTTP:JSONEncode({
                name = LP.Name,
                challenge = challengeData.question,
                challenge_token = challengeData.token
            })
            local regOk, regRes = pcall(req, {
                Url = API_URL .. "/register",
                Method = "POST",
                Headers = DEFAULT_HEADERS,
                Body = registerBody
            })
            if regOk and regRes and regRes.StatusCode == 200 then
                local ok3, regData = pcall(HTTP.JSONDecode, HTTP, regRes.Body)
                if ok3 and regData and regData.token then
                    sessionToken = regData.token
                    showNotification("Сервер", "Подключение установлено")
                    print("[NeonChat] Сессия получена:", sessionToken:sub(1,8) .. "...")
                else
                    showNotification("Сервер", "Ошибка регистрации: неверный ответ")
                end
            else
                local status = regOk and regRes and regRes.StatusCode or "?"
                local body = regOk and regRes and tostring(regRes.Body):sub(1,100) or ""
                warn("[NeonChat] /register ошибка:", status, body)
                showNotification("Сервер", "Регистрация не удалась (" .. tostring(status) .. ")")
            end
        else
            showNotification("Сервер", "Ошибка challenge")
        end
    else
        showNotification("Сервер", "Не удалось получить challenge")
    end
end)

