local function updateColorWheel(i)
    local cx, cy = CW.AbsolutePosition.X + CW.AbsoluteSize.X / 2, CW.AbsolutePosition.Y + CW.AbsoluteSize.Y / 2
    local dx, dy = i.Position.X - cx, i.Position.Y - cy
    local dist = math.sqrt(dx * dx + dy * dy)
    local maxR = 45
    if dist > maxR then dx = (dx/dist)*maxR; dy = (dy/dist)*maxR; dist = maxR end
    dot.Position = UDim2.new(0, dx + maxR, 0, dy + maxR)
    local hue = math.atan2(dy, dx) / (math.pi * 2)
    if hue < 0 then hue = hue + 1 end
    col = Color3.fromHSV(hue, math.clamp(dist / maxR, 0, 1), 1)
    
    prv.BackgroundColor3 = col
    MBStroke.Color = col
    MB.TextColor3 = col
    HT.TextColor3 = col
    SndBtn.TextColor3 = col
    CL.ScrollBarImageColor3 = col
    SC.ScrollBarImageColor3 = col
    GF.ScrollBarImageColor3 = col
    IslandStroke.Color = col
    IslandText.TextColor3 = col
end

local wheelDown = false
CW.InputBegan:Connect(function(i) if i.UserInputType.Name:match("MouseButton1|Touch") then wheelDown = true updateColorWheel(i) end end)
UIS.InputChanged:Connect(function(i) if wheelDown and i.UserInputType.Name:match("MouseMovement|Touch") then updateColorWheel(i) end end)
UIS.InputEnded:Connect(function(i) if i.UserInputType.Name:match("MouseButton1|Touch") then wheelDown = false end end)

