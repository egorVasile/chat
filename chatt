	if transitionInProgress or tab == currentTab then return end
	transitionInProgress = true

	local fromTab = currentTab
	currentTab = tab

	HT.Text = tab == "settings" and "⚙️ НАСТРОЙКИ" or (tab == "gifs" and "🖼️ СТИКЕРЫ" or "🤫 SECRET GLOBAL CHAT")
