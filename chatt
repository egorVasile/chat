local lastId, firstPoll = 0, true
task.spawn(function()
    if not req then return end
    while SG.Parent do
        local ok, res = pcall(req, { Url = API_URL .. "/messages?after=" .. lastId, Method = "GET" })
        if ok and res and res.StatusCode == 200 then
            if firstPoll then drawMessage("SYSTEM", "Успешно подключено к серверу!", Color3.fromRGB(0, 255, 100), "sq", "none", "none", true, false, false, "") end
            local ok2, msgs = pcall(HTTP.JSONDecode, HTTP, res.Body)
            if ok2 and type(msgs) == "table" then
                for _, m in ipairs(msgs) do
                    if type(m) == "table" and m.id then
                        lastId = math.max(lastId, m.id)
                        if not myIds[m.id] then
                            local t = { bs="none", fx="none", mf="none", b=false, i=false, u=false, gn="" }
                            for k, v in (m.meta or ""):gmatch("(%w+)=([^;]+)") do if k=="bs" then t.bs=v elseif k=="fx" then t.fx=v elseif k=="mf" then t.mf=v elseif k=="b" then t.b=(v=="1") elseif k=="i" then t.i=(v=="1") elseif k=="u" then t.u=(v=="1") elseif k=="gn" then t.gn=v:gsub("_", " ") end end
                            local r, g, b = tostring(m.color or ""):match("(%d+),(%d+),(%d+)")
                            drawMessage(tostring(m.name or "Anon"), tostring(m.text or ""), (r and Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b)) or Color3.new(1,1,1)), t.bs, t.fx, t.mf, t.b, t.i, t.u, t.gn)
                        end
                    end
                end
            end
        elseif firstPoll then drawMessage("SYSTEM", "Нет связи с сервером.", Color3.fromRGB(255, 50, 50), "sq", "none", "none", true, false, false, "") end
        firstPoll = false task.wait(1.5)
    end
end)

local function makeDraggable(t, h)
    local drag, startPos, dragStart = false, nil, nil
    h.InputBegan:Connect(function(i) if i.UserInputType.Name:match("MouseButton1|Touch") then drag = true startPos, dragStart = t.Position, i.Position end end)
    UIS.InputChanged:Connect(function(i) if drag and i.UserInputType.Name:match("MouseMovement|Touch") then t.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + (i.Position - dragStart).X, startPos.Y.Scale, startPos.Y.Offset + (i.Position - dragStart).Y) end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType.Name:match("MouseButton1|Touch") then drag = false end end)
end
makeDraggable(MB, MB) makeDraggable(MF, HD) makeDraggable(Island, Island)

