-- Упаковка стилей в компактную meta-строку
local function packMeta()
    return string.format("bs=%s;fx=%s;mf=%s;b=%d;i=%d;u=%d;s=%d",
        bStyle, fx, msgFx,
        isB and 1 or 0, isI and 1 or 0, isU and 1 or 0, isS and 1 or 0)
end

local function unpackMeta(meta)
    local t = { bs = "none", fx = "none", mf = "none", b = false, i = false, u = false, s = false }
    if type(meta) ~= "string" then return t end
    for k, v in meta:gmatch("(%w+)=([%w]+)") do
        if k == "bs" then t.bs = v
        elseif k == "fx" then t.fx = v
        elseif k == "mf" then t.mf = v
        elseif k == "b" then t.b = (v == "1")
        elseif k == "i" then t.i = (v == "1")
        elseif k == "u" then t.u = (v == "1")
        elseif k == "s" then t.s = (v == "1") end
    end
    return t
end

local function parseColor(str)
    local r, g, b = tostring(str or ""):match("(%d+),(%d+),(%d+)")
    if r then
        return Color3.fromRGB(math.clamp(tonumber(r), 0, 255), math.clamp(tonumber(g), 0, 255), math.clamp(tonumber(b), 0, 255))
    end
    return Color3.new(1, 1, 1)
end

-- id сообщений, которые отправили МЫ — чтобы не рисовать их дважды при опросе
local myIds = {}

-- Отправка на сервер
local function sendMessage()
    local text = IB.Text
    if text == "" or isSO then return end
    if text:gsub("%s", "") == "" then return end
    if not req then
        systemMsg("Нет HTTP-функции у экзекутора")
        return
    end
    IB.Text = ""

    -- рисуем сразу у себя (не ждём опроса сервера)
    drawMessage(LP.Name, text, col, bStyle, fx, msgFx, isB, isI, isU, isS)

    local body = HTTP:JSONEncode({
        name = LP.Name,
        text = text,
        color = string.format("%d,%d,%d",
            math.floor(col.R * 255), math.floor(col.G * 255), math.floor(col.B * 255)),
        meta = packMeta(),
    })

    task.spawn(function()
        local ok, res = pcall(req, {
            Url = API_URL .. "/send",
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = body,
        })
        if ok and res and res.StatusCode == 200 then
            local ok2, data = pcall(HTTP.JSONDecode, HTTP, res.Body)
            if ok2 and type(data) == "table" and data.id then
                myIds[data.id] = true -- запомним, чтобы опрос не продублировал
            end
        elseif ok and res and res.StatusCode == 429 then
            systemMsg("Слишком быстро! Подожди секунду.")
        else
            systemMsg("Не удалось отправить (сервер недоступен?)")
        end
    end)
end

-- Опрос сервера: получаем новые сообщения раз в 1.5 секунды
local lastId = 0
local firstPoll = true
task.spawn(function()
    if not req then return end
    if API_URL:find("ВСТАВЬ") then
        systemMsg("Вставь URL сервера в API_URL вверху скрипта!")
        return
    end
    while SG.Parent do
        local ok, res = pcall(req, {
            Url = API_URL .. "/messages?after=" .. lastId,
            Method = "GET",
        })
        if ok and res and res.StatusCode == 200 then
            if firstPoll then
                systemMsg("Подключено к серверу!")
            end
            local ok2, msgs = pcall(HTTP.JSONDecode, HTTP, res.Body)
            if ok2 and type(msgs) == "table" then
                for _, m in ipairs(msgs) do
                    if type(m) == "table" and m.id then
                        lastId = math.max(lastId, m.id)
                        -- при первом опросе грузим историю, свои дубли пропускаем
                        if not myIds[m.id] then
                            local st = unpackMeta(m.meta)
                            drawMessage(
                                tostring(m.name or "Anon"),
                                tostring(m.text or ""),
                                parseColor(m.color),
                                st.bs, st.fx, st.mf,
                                st.b, st.i, st.u, st.s
                            )
                        end
                    end
                end
            end
        elseif firstPoll then
            systemMsg("Сервер недоступен. Проверь URL и что Colab запущен.")
        end
        firstPoll = false
        task.wait(1.5)
    end
end)

