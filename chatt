    nameLabel.TextColor3 = isMine and Color3.new(1,1,1) or color
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 11
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left

    local gifId = isGifText(payload)
    if gifId then
        local img = Instance.new("ImageLabel", bubble)
        img.Size = UDim2.new(0,95,0,95)
        img.Position = UDim2.new(0,8,0,21)
        img.BackgroundTransparency = 1
        img.Image = "rbxassetid://" .. gifId
        img.ScaleType = Enum.ScaleType.Fit
        bubble.Size = UDim2.new(0.42,0,0,124)
        wrap.Size = UDim2.new(1,0,0,126)

        task.spawn(function()
            local resolved = resolveImageId(gifId)
            if img and img.Parent then
                img.Image = "rbxassetid://" .. resolved
            end
        end)
    else
        local txt = Instance.new("TextLabel", bubble)
        txt.Size = UDim2.new(1,-14,0,18)
        txt.Position = UDim2.new(0,7,0,19)
        txt.BackgroundTransparency = 1
