--// ===================== POLLING =====================
local lastId, firstPoll = 0, true

task.spawn(function()
	if not req then return end
	task.wait(2)

	local ok, res = pcall(req, {Url = API_URL .. "/health", Method = "GET", Headers = GET_HEADERS})
	if ok and res and res.StatusCode == 200 then
		local challengeOk, challengeRes = pcall(req, {Url = API_URL .. "/challenge", Method = "GET", Headers = GET_HEADERS})
		if challengeOk and challengeRes and challengeRes.StatusCode == 200 then
			local ok2, challengeData = pcall(HTTP.JSONDecode, HTTP, challengeRes.Body)
			if ok2 and challengeData and challengeData.question and challengeData.token then
				local regOk, regRes = pcall(req, {
					Url = API_URL .. "/register",
					Method = "POST",
					Headers = DEFAULT_HEADERS,
					Body = HTTP:JSONEncode({name = LP.Name, challenge = challengeData.question, challenge_token = challengeData.token})
				})
				if regOk and regRes and regRes.StatusCode == 200 then
					local ok3, regData = pcall(HTTP.JSONDecode, HTTP, regRes.Body)
					if ok3 and regData and regData.token then
						sessionToken = regData.token
						showNotification("Сервер", "Подключение установлено", "✅")
						-- Send initial status
						pcall(function()
							req({Url = API_URL .. "/status", Method = "POST", Headers = DEFAULT_HEADERS,
								Body = HTTP:JSONEncode({name = LP.Name, status = myStatus, token = sessionToken})})
						end)
					end
				end
			end
		end
	end
end)

task.spawn(function()
	if not req then
		drawMessage("SYSTEM", "HTTP request не найден", Color3.fromRGB(255, 80, 80), "sq", "none", "none", true, false, false, false, "", "global")
		return
	end

	while SG.Parent do
		local ok, res = pcall(req, {Url = API_URL .. "/messages?after=" .. lastId, Method = "GET", Headers = GET_HEADERS})
		if ok and res and res.StatusCode == 200 then
			if firstPoll then drawMessage("SYSTEM", "Подключено к серверу!", Color3.fromRGB(0, 255, 110), "sq", "none", "none", true, false, false, false, "", "global") end

			local ok2, msgs = pcall(HTTP.JSONDecode, HTTP, res.Body)
			if ok2 and type(msgs) == "table" then
				for _, m in ipairs(msgs) do
					if type(m) == "table" and m.id then
						lastId = math.max(lastId, m.id)
						local key = tostring(m.name or "") .. "|" .. tostring(m.text or "")
						local pendingTime = pendingLocal[key]
						if not myIds[m.id] and not (pendingTime and (tick() - pendingTime < 5)) then
							local pmTarget, pmPayload = parsePMText(m.text)
							if pmTarget then
								handleIncoming(m)
							else
								local mChan = m.channel or "global"
								local name, text, color, st = tostring(m.name or "Anon"), tostring(m.text or ""), parseColor(m.color), unpackMeta(m.meta)
								local replyData = m.reply_to and {id = m.reply_to, name = m.reply_name or "", text = m.reply_text or ""} or nil
								drawMessage(name, text, color, st.bs, st.fx, st.mf, st.b, st.i, st.u, st.s, st.gn, mChan, m.id, replyData, m.reactions, m.edited)
							end
						end
					end
				end
			end
		elseif firstPoll then
			drawMessage("SYSTEM", "Сервер недоступен. Проверь API_URL.", Color3.fromRGB(255, 70, 70), "sq", "none", "none", true, false, false, false, "", "global")
		end

		-- Typing sync
		pcall(function()
			local okT, resT = req({Url = API_URL .. "/typing?channel=" .. activeChannel, Method = "GET", Headers = GET_HEADERS})
			if okT and resT and resT.StatusCode == 200 then
				local okT2, list = pcall(HTTP.JSONDecode, HTTP, resT.Body)
				if okT2 and type(list) == "table" then
					typingUsers = {}
					for _, n in ipairs(list) do
						if n:lower() ~= LP.Name:lower() then typingUsers[n] = tick() end
					end
					updateTyping()
				end
			end
		end)

		-- Channels sync
		pcall(function()
			local okC, resC = req({Url = API_URL .. "/channels", Method = "GET", Headers = GET_HEADERS})
			if okC and resC and resC.StatusCode == 200 then
				local okC2, list = pcall(HTTP.JSONDecode, HTTP, resC.Body)
				if okC2 and type(list) == "table" then
					local temp = {"global", "local"}
					for _, ch in ipairs(list) do
						if ch ~= "global" and ch ~= "local" then table.insert(temp, ch) end
					end
					channelsList = temp
					refreshChannelsList()
				end
			end
		end)

		-- Pinned sync
		pcall(function()
			local okP, resP = req({Url = API_URL .. "/pins?channel=" .. activeChannel, Method = "GET", Headers = GET_HEADERS})
			if okP and resP and resP.StatusCode == 200 then
				local okP2, list = pcall(HTTP.JSONDecode, HTTP, resP.Body)
				if okP2 and type(list) == "table" and #list > 0 then
					local pin = list[#list]
					if pin.text and pin.text ~= PinLabel.Text then
						PinBar.Visible = true
						TS:Create(PinBar, tweenFast, {Size = UDim2.new(1, -148, 0, 34)}):Play()
						PinLabel.Text = "📌 " .. escapeRich(pin.text):sub(1, 80)
					end
				end
			end
		end)

		firstPoll = false
		task.wait(1.4)
	end
end)

