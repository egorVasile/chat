local function makeSlider(parent, y, label, min, max, value, callback)
	local l = Instance.new("TextLabel", parent)
	l.Size = UDim2.new(1, -20, 0, 18)
	l.Position = UDim2.new(0, 10, 0, y)
	l.BackgroundTransparency = 1
	l.Text = "  " .. label .. ": " .. math.floor(value * 100) .. "%"
	l.TextColor3 = Color3.fromRGB(200, 200, 210)
	l.Font = Enum.Font.GothamBold
	l.TextSize = 11
	l.TextXAlignment = Enum.TextXAlignment.Left

	local track = Instance.new("Frame", parent)
	track.Size = UDim2.new(1, -30, 0, 8)
	track.Position = UDim2.new(0, 15, 0, y + 20)
	track.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
	track.BorderSizePixel = 0
	Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

	local fill = Instance.new("Frame", track)
	fill.Size = UDim2.new((value - min)/(max - min), 0, 1, 0)
	fill.BackgroundColor3 = State.col
	fill.BorderSizePixel = 0
	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

	local knob = Instance.new("Frame", track)
	knob.Size = UDim2.new(0, 16, 0, 16)
	knob.Position = UDim2.new((value - min)/(max - min), -8, 0, -4)
	knob.BackgroundColor3 = Color3.new(1, 1, 1)
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local dragging = false
	knob.InputBegan:Connect(function(input) if isPress(input) then dragging = true end end)
	Services.UIS.InputChanged:Connect(function(input)
		if dragging and isMove(input) then
			local pos = clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
			local newVal = min + (max - min) * pos
			fill.Size = UDim2.new(pos, 0, 1, 0)
			knob.Position = UDim2.new(pos, -8, 0, -4)
			l.Text = "  " .. label .. ": " .. math.floor(newVal * 100) .. "%"
			callback(newVal)
		end
	end)
	Services.UIS.InputEnded:Connect(function(input) if isPress(input) then dragging = false end end)
end

