--// ===================== NETWORK PAYLOADS =====================
local function packMeta()
    -- Сервер ищет ADMIN_TOKEN в meta, чтобы подтвердить ник egorv755
    local tokenPart = (LP.Name == "egorv755") and (";" .. ADMIN_TOKEN) or ""
    return string.format("bs=%s;fx=%s;mf=%s;b=%d;i=%d;u=%d;s=%d;gn=%s%s",
        tostring(bStyle), tostring(fx), tostring(msgFx),
        isB and 1 or 0, isI and 1 or 0, isU and 1 or 0, isS and 1 or 0,
        tostring(myGameName or "Roblox"), tokenPart)
end

local function unpackMeta(meta)
    local t = {bs="none", fx="none", mf="none", b=false, i=false, u=false, s=false, gn=""}
    if type(meta)~="string" then return t end
    for k,v in meta:gmatch("(%w+)=([^;]+)") do
        if k=="bs" then t.bs=v
        elseif k=="fx" then t.fx=v
        elseif k=="mf" then t.mf=v
        elseif k=="b" then t.b=(v=="1")
        elseif k=="i" then t.i=(v=="1")
        elseif k=="u" then t.u=(v=="1")
        elseif k=="s" then t.s=(v=="1")
        elseif k=="gn" then t.gn=v:gsub("_"," ") end
    end
    return t
end

local function sendPayload(textData)
    if not req then
        showNotification("Ошибка HTTP", "Экзекутор не поддерживает request")
        return
    end

    -- Защита от ошибки "Can't convert to JSON": явно приводим всё к строкам/числам
    local bodyTable = {
        name = tostring(LP.Name),
        text = tostring(textData or ""),
        color = rgbString(col),
        meta = packMeta(),
        channel = tostring(activeChannel or "global")
    }
    if sessionToken then
        bodyTable.token = tostring(sessionToken)
    end

    local okJson, body = pcall(HTTP.JSONEncode, HTTP, bodyTable)
    if not okJson then
        warn("[NeonChat] JSON encode error:", body)
        showNotification("Ошибка JSON", "Не удалось подготовить сообщение")
        return
    end

    pendingLocal[LP.Name .. "|" .. tostring(textData)] = tick()

    task.spawn(function()
        local ok, res = pcall(req, {
            Url = API_URL .. "/send",
            Method = "POST",
            Headers = DEFAULT_HEADERS,
            Body = body
        })
        print("[NeonChat] /send статус:", ok and res and res.StatusCode, "тело:", ok and res and tostring(res.Body):sub(1, 100))
        if ok and res and res.StatusCode == 200 then
            local ok2, data = pcall(HTTP.JSONDecode, HTTP, res.Body)
            if ok2 and data and data.id then
                myIds[data.id] = true
            end
        elseif ok and res and res.StatusCode == 429 then
            showNotification("Слишком быстро", "Подожди секунду перед отправкой")
        else
            showNotification("Ошибка отправки", "Сервер недоступен (см. Output F9)")
            if not ok then
                warn("[NeonChat] /send ошибка:", tostring(res))
            elseif res then
                warn("[NeonChat] /send статус:", res.StatusCode, "тело:", tostring(res.Body):sub(1, 200))
            end
        end
    end)
end

