	local names = {}
	for n, t in pairs(State.typingUsers) do
		if tick() - t < 4 then
			table.insert(names, safeName(n))
		else
			State.typingUsers[n] = nil
		end
	end
	if #names > 0 then
		local text = table.concat(names, ", ")
		if #names == 1 then
			UI.TypingLabel.Text = text .. " печатает..."
		else
			UI.TypingLabel.Text = text .. " печатают..."
		end
		Services.TS:Create(UI.TypingBar, Tween.Fast, {Size = UDim2.new(1, -148, 0, 20)}):Play()
	else
		Services.TS:Create(UI.TypingBar, Tween.Fast, {Size = UDim2.new(1, -148, 0, 0)}):Play()
	end
end

