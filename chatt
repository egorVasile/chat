local function drawMessageDirect(uName, text, nColor, nStyle, nFx, mStyleFx, wB, wI, wU, wS, senderGame, msgId, replyData, reactions, isEdited)
	uName, text = tostring(uName or "Anon"), tostring(text or "")
	if State.blockedUsers[safeName(uName):lower()] then return end

	local frames = {}
	for _, c in ipairs(UI.CL:GetChildren()) do
		if c:IsA("Frame") then table.insert(frames, c) end
	end
	if #frames >= MAX_MESSAGES then frames[1]:Destroy() end

	local isGif = isGifText(text)
	local frameHeight = isGif and 110 or 38

	local mf = Instance.new("Frame")
	mf.Name = "Message_" .. (msgId or uName)
	mf.BackgroundTransparency = 1
	mf.Size = UDim2.new(1, -8, 0, frameHeight)
	mf.Position = UDim2.new(0, 4, 0, 0)
	mf.ClipsDescendants = false
	mf.Parent = UI.CL
	mf.ZIndex = 2
	if msgId then State.messageFrames[msgId] = mf end
	Instance.new("UICorner", mf).CornerRadius = UDim.new(0, 8)

	local hover = Instance.new("Frame", mf)
	hover.Name = "Hover"
	hover.Size = UDim2.new(1, 0, 1, 0)
	hover.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	hover.BackgroundTransparency = 1
	hover.ZIndex = 1
	Instance.new("UICorner", hover).CornerRadius = UDim.new(0, 8)

	mf.MouseEnter:Connect(function()
		Services.TS:Create(hover, Tween.Fast, {BackgroundTransparency = 0.96}):Play()
	end)
	mf.MouseLeave:Connect(function()
		Services.TS:Create(hover, Tween.Fast, {BackgroundTransparency = 1}):Play()
	end)

	mf.InputBegan:Connect(function(input)
		if isRightClick(input) and uName ~= "SYSTEM" then
			State.selectedUser = safeName(uName)
			local mouse = Services.UIS:GetMouseLocation()
			UI.CMenu.Position = UDim2.new(0, clamp(mouse.X + 4, 0, 1200), 0, clamp(mouse.Y + 4, 0, 600))
			UI.CTitle.Text = "👤 " .. State.selectedUser

			local isMine = State.selectedUser:lower() == LP.Name:lower()
			UI.btnEdit.Visible = isMine and msgId ~= nil
			UI.btnDelete.Visible = isMine and msgId ~= nil
			UI.btnPin.Visible = LP.Name == "egorv755"
			UI.btnBlock.Text = State.blockedUsers[State.selectedUser:lower()] and "✅ Разблокировать" or "🚫 Заблокировать"

			UI.CMenu.Visible = true
			UI.CMenu:SetAttribute("msgId", msgId or "")
			UI.CMenu:SetAttribute("msgText", text)
			UI.CMenu:SetAttribute("msgFrame", mf)
		end
	end)

	local cg = Instance.new("CanvasGroup", mf)
	cg.Size = UDim2.new(1, 0, 1, 0)
	cg.BackgroundTransparency = 1
	cg.GroupTransparency = 0.15
	cg.ZIndex = 2

	Services.TS:Create(cg, Tween.Soft, {GroupTransparency = 0}):Play()

	local yOffset = 2

	if replyData and replyData.name then
		local replyLabel = Instance.new("TextLabel", cg)
		replyLabel.Size = UDim2.new(1, -12, 0, 16)
		replyLabel.Position = UDim2.new(0, 6, 0, yOffset)
		replyLabel.BackgroundTransparency = 1
		replyLabel.Text = "↩️ " .. safeName(replyData.name) .. ": " .. escapeRich(replyData.text):sub(1, 40)
		replyLabel.TextColor3 = Color3.fromRGB(150, 150, 160)
		replyLabel.Font = Enum.Font.Gotham
		replyLabel.TextSize = 11
		replyLabel.TextXAlignment = Enum.TextXAlignment.Left
		replyLabel.TextTruncate = Enum.TextTruncate.AtEnd
		yOffset = yOffset + 16
	end

	local nameLabel = Instance.new("TextLabel", cg)
	nameLabel.Size = UDim2.new(0, 260, 0, 22)
	nameLabel.Position = UDim2.new(0, 6, 0, yOffset)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextSize = 12
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.TextColor3 = nColor
	nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
	nameLabel.RichText = false
	nameLabel.ZIndex = 3

	local displayName = uName
	if nStyle == "sq" then displayName = "[" .. displayName .. "]"
	elseif nStyle == "round" then displayName = "(" .. displayName .. ")"
	elseif nStyle == "ang" then displayName = "<" .. displayName .. ">"
	elseif nStyle == "curly" then displayName = "{" .. displayName .. "}" end

	local role = ROLES[uName]
	if role then
		displayName = role.tag .. " " .. displayName
		nColor = role.color
		nameLabel.TextColor3 = role.color
		if role.effect and role.effect ~= "none" then nFx = role.effect end
	end

	local gameTag = (senderGame and senderGame ~= "" and senderGame ~= "Roblox") and ("[" .. senderGame .. "] ") or ""
	nameLabel.Text = os.date("%H:%M") .. " " .. gameTag .. displayName .. (isEdited and " (изм.)" or "")

	applyNameEffect(nameLabel, mf, nFx, nColor)

	if isGif then
		local contentOffset = clamp(nameLabel.TextBounds.X + 8, 110, math.max(120, UI.CL.AbsoluteSize.X - 140))
		local img = Instance.new("ImageLabel", cg)
		img.Position = UDim2.new(0, contentOffset, 0, yOffset + 2)
		img.Size = UDim2.new(0, 84, 0, 84)
		img.BackgroundTransparency = 1
		img.Image = "rbxassetid://" .. isGif
		img.ScaleType = Enum.ScaleType.Stretch
		img.ImageColor3 = Color3.new(1, 1, 1)
		img.ZIndex = 10

		applyWorkingImage(img, isGif)

		if reactions then
			local reactContainer = Instance.new("Frame", cg)
			reactContainer.Size = UDim2.new(0, 200, 0, 20)
			reactContainer.Position = UDim2.new(0, contentOffset, 0, yOffset + 88)
			reactContainer.BackgroundTransparency = 1
			local rx = 0
			for emoji, count in pairs(reactions) do
				local r = Instance.new("TextLabel", reactContainer)
				r.Size = UDim2.new(0, 34, 0, 18)
				r.Position = UDim2.new(0, rx, 0, 0)
				r.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
				r.BackgroundTransparency = 0.3
				r.Text = emoji .. " " .. tostring(count)
				r.TextColor3 = Color3.fromRGB(245, 245, 255)
				r.Font = Enum.Font.GothamBold
				r.TextSize = 10
				Instance.new("UICorner", r).CornerRadius = UDim.new(0, 6)
				rx = rx + 38
			end
		end
		return
	end

	local textLabel = Instance.new("TextLabel", cg)
	textLabel.BackgroundTransparency = 1
	textLabel.Font = Enum.Font.Gotham
	textLabel.TextSize = 13
	textLabel.TextXAlignment = Enum.TextXAlignment.Left
	textLabel.TextYAlignment = Enum.TextYAlignment.Top
	textLabel.RichText = true
	textLabel.TextWrapped = true
	textLabel.TextColor3 = Color3.fromRGB(240, 240, 248)
	textLabel.ZIndex = 3

	local str = escapeRich(text)
	local lowerStr = string.lower(str)
	local lowerName = string.lower(LP.Name)
	local sIdx, eIdx = lowerStr:find("@" .. lowerName, 1, true)
	if sIdx then
		local actualMention = str:sub(sIdx, eIdx)
		str = str:sub(1, sIdx - 1) .. '<font color="rgb(255,100,100)"><b>' .. actualMention .. '</b></font>' .. str:sub(eIdx + 1)
		if uName ~= LP.Name then showNotification("Упоминание", uName .. " упомянул вас", "🔔") end
	end
	if wB then str = "<b>" .. str .. "</b>" end
	if wI then str = "<i>" .. str .. "</i>" end
	if wU then str = "<u>" .. str .. "</u>" end
	if wS then str = "<s>" .. str .. "</s>" end
	textLabel.Text = str

	task.defer(function()
		if not mf.Parent then return end
		local contentOffset = clamp(nameLabel.TextBounds.X + 8, 95, math.max(120, math.floor(UI.CL.AbsoluteSize.X * 0.55)))
		textLabel.Position = UDim2.new(0, contentOffset, 0, yOffset)
		textLabel.Size = UDim2.new(1, -contentOffset - 8, 0, 24)

		local h = math.max(28, textLabel.TextBounds.Y + 4)
		textLabel.Size = UDim2.new(1, -contentOffset - 8, 0, h)
		mf.Size = UDim2.new(1, -8, 0, yOffset + h + 8)
		cg.Size = UDim2.new(1, 0, 1, 0)

		applyTextEffect(textLabel, mf, mStyleFx, nColor, textLabel.Position)

		if reactions then
			local reactContainer = Instance.new("Frame", cg)
			reactContainer.Size = UDim2.new(1, -contentOffset - 8, 0, 20)
			reactContainer.Position = UDim2.new(0, contentOffset, 0, yOffset + h + 2)
			reactContainer.BackgroundTransparency = 1
			local rx = 0
			for emoji, count in pairs(reactions) do
				local r = Instance.new("TextLabel", reactContainer)
				r.Size = UDim2.new(0, 34, 0, 18)
				r.Position = UDim2.new(0, rx, 0, 0)
				r.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
				r.BackgroundTransparency = 0.3
				r.Text = emoji .. " " .. tostring(count)
				r.TextColor3 = Color3.fromRGB(245, 245, 255)
				r.Font = Enum.Font.GothamBold
				r.TextSize = 10
				Instance.new("UICorner", r).CornerRadius = UDim.new(0, 6)
				rx = rx + 38
			end
		end
	end)
end

--// ===================== CHANNELS & SETTINGS =====================
local function drawMessage(uName, text, nColor, nStyle, nFx, mStyleFx, wB, wI, wU, wS, senderGame, chan, msgId, replyData, reactions, isEdited)
	chan = chan or State.activeChannel
	State.channelHistory[chan] = State.channelHistory[chan] or {}

	table.insert(State.channelHistory[chan], {
		name = uName, text = text, color = nColor, bs = nStyle, fx = nFx, mf = mStyleFx,
		b = wB, i = wI, u = wU, s = wS, gn = senderGame, id = msgId, reply = replyData,
		reactions = reactions, edited = isEdited
	})
	if #State.channelHistory[chan] > MAX_MESSAGES then table.remove(State.channelHistory[chan], 1) end

	if State.activeChannel == chan then
		drawMessageDirect(uName, text, nColor, nStyle, nFx, mStyleFx, wB, wI, wU, wS, senderGame, msgId, replyData, reactions, isEdited)
	end
end

local function refreshChannelsList()
	for _, b in pairs(State.channelButtons) do b:Destroy() end
	State.channelButtons = {}

	for _, ch in ipairs(State.channelsList) do
		local dName = ch == "global" and "🌐 Глобал" or (ch == "local" and "🏠 Локал" or "💬 " .. ch)
		local btn = Instance.new("TextButton", UI.ChannelsPanel)
		btn.Size = UDim2.new(1, -6, 0, 28)
		btn.BackgroundColor3 = (State.activeChannel == ch) and State.col or Color3.fromRGB(24, 24, 34)
		btn.BackgroundTransparency = (State.activeChannel == ch) and 0.2 or 0.5
		btn.TextColor3 = (State.activeChannel == ch) and Color3.new(0, 0, 0) or Color3.fromRGB(220, 220, 230)
		btn.Font = Enum.Font.GothamBold
		btn.TextSize = 10
		btn.Text = dName
		btn.AutoButtonColor = false
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

		btn.MouseButton1Click:Connect(function()
			State.activeChannel = ch
			refreshChannelsList()
			for _, c in ipairs(UI.CL:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
			local hist = State.channelHistory[ch] or {}
			for _, m in ipairs(hist) do
				drawMessageDirect(m.name, m.text, m.color, m.bs, m.fx, m.mf, m.b, m.i, m.u, m.s, m.gn, m.id, m.reply, m.reactions, m.edited)
			end
		end)

		if LP.Name == "egorv755" and ch ~= "global" and ch ~= "local" then
			btn.InputBegan:Connect(function(input)
				if isRightClick(input) then
					pcall(function()
						req({
							Url = API_URL .. "/channels/delete",
							Method = "POST",
							Headers = DEFAULT_HEADERS,
							Body = Services.HTTP:JSONEncode({name = LP.Name, channel = ch})
						})
					end)
				end
			end)
		end
		table.insert(State.channelButtons, btn)
	end
end
