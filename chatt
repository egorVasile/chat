local function switchTab(tab)
    if currentTab == tab then tab = "chat" end
    currentTab = tab
    
    HT.Text = tab == "settings" and "⚙️ НАСТРОЙКИ" or (tab == "gifs" and "🖼️ ВЫБОР СТИКЕРА" or "🤫 SECRET GLOBAL CHAT")
    TS:Create(SB, tweenInfoFast, {Rotation = tab == "settings" and 90 or 0}):Play()
    TS:Create(GB, tweenInfoFast, {Size = tab == "gifs" and UDim2.new(0,38,0,38) or UDim2.new(0,32,0,32)}):Play()

    if tab == "chat" then
        TS:Create(CL, tweenInfoBounce, {Position = UDim2.new(0, 12, 0, 50)}):Play()
        TS:Create(SC, tweenInfoFast, {Position = UDim2.new(1, 0, 0, 50)}):Play()
        TS:Create(GF, tweenInfoFast, {Position = UDim2.new(-1, 0, 0, 50)}):Play()
    elseif tab == "settings" then
        SC.Visible = true
        TS:Create(CL, tweenInfoFast, {Position = UDim2.new(-1, 0, 0, 50)}):Play()
        TS:Create(SC, tweenInfoBounce, {Position = UDim2.new(0, 0, 0, 50)}):Play()
        TS:Create(GF, tweenInfoFast, {Position = UDim2.new(-1, 0, 0, 50)}):Play()
    elseif tab == "gifs" then
        GF.Visible = true
        TS:Create(CL, tweenInfoFast, {Position = UDim2.new(1, 0, 0, 50)}):Play()
        TS:Create(SC, tweenInfoFast, {Position = UDim2.new(1, 0, 0, 50)}):Play()
