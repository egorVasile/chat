	TS:Create(GB, tweenFast, {Size = tab == "gifs" and UDim2.new(0, 36, 0, 36) or UDim2.new(0, 32, 0, 32)}):Play()

	if tab == "chat" then
		SearchBox.Visible = false
		-- Slide out current panel
		if fromTab == "settings" then
			TS:Create(SettingsGroup, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(1, 0, 0, 50), GroupTransparency = 1}):Play()
		elseif fromTab == "gifs" then
			TS:Create(GF, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(-1, 0, 0, 50)}):Play()
