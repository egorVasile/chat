local function showNotification(title, desc)
    local snd = Instance.new("Sound", workspace)
    snd.SoundId, snd.Volume = "rbxassetid://6042053626", 1.5
    snd:Play()
    Debris:AddItem(snd, 2)

    local nf = Instance.new("Frame", NotifFrame)
    nf.Size, nf.BackgroundColor3, nf.BackgroundTransparency, nf.ClipsDescendants, nf.Position =
        UDim2.new(1,0,0,68), Color3.fromRGB(18,18,26), 1, true, UDim2.new(0,45,0,0)
    Instance.new("UICorner", nf).CornerRadius = UDim.new(0,10)
    local st = Instance.new("UIStroke", nf)
    st.Color, st.Thickness, st.Transparency = col, 1.5, 1
    local tL = Instance.new("TextLabel", nf)
    tL.Size, tL.Position, tL.BackgroundTransparency, tL.Text, tL.TextColor3, tL.Font, tL.TextSize, tL.TextXAlignment, tL.TextTransparency =
        UDim2.new(1,-20,0,22), UDim2.new(0,10,0,9), 1, title, col, Enum.Font.GothamBold, 14, Enum.TextXAlignment.Left, 1
    local dL = Instance.new("TextLabel", nf)
    dL.Size, dL.Position, dL.BackgroundTransparency, dL.Text, dL.TextColor3, dL.Font, dL.TextSize, dL.TextXAlignment, dL.TextWrapped, dL.TextTransparency =
        UDim2.new(1,-20,0,30), UDim2.new(0,10,0,31), 1, desc, Color3.fromRGB(235,235,245), Enum.Font.Gotham, 12, Enum.TextXAlignment.Left, true, 1

    TS:Create(nf, tweenSoft, {BackgroundTransparency=0.08, Position=UDim2.new(0,0,0,0)}):Play()
    TS:Create(st, tweenSoft, {Transparency=0}):Play()
    TS:Create(tL, tweenSoft, {TextTransparency=0}):Play()
    TS:Create(dL, tweenSoft, {TextTransparency=0}):Play()

    task.delay(4.2, function()
        if not nf.Parent then return end
        TS:Create(nf, TweenInfo.new(0.35), {BackgroundTransparency=1, Position=UDim2.new(0,45,0,0)}):Play()
        TS:Create(st, TweenInfo.new(0.35), {Transparency=1}):Play()
        TS:Create(tL, TweenInfo.new(0.35), {TextTransparency=1}):Play()
        local tw = TS:Create(dL, TweenInfo.new(0.35), {TextTransparency=1})
        tw:Play()
        tw.Completed:Connect(function() if nf then nf:Destroy() end end)
    end)
end

