--// ===================== NETWORK =====================
local function packMeta()
	local tokenPart = (LP.Name == "egorv755") and (";" .. ADMIN_TOKEN) or ""
	return string.format("bs=%s;fx=%s;mf=%s;b=%d;i=%d;u=%d;s=%d;gn=%s;status=%s%s",
		tostring(bStyle), tostring(fx), tostring(msgFx),
		isB and 1 or 0, isI and 1 or 0, isU and 1 or 0, isS and 1 or 0,
		tostring(myGameName or "Roblox"), tostring(myStatus), tokenPart)
end

local function unpackMeta(meta)
	local t = {bs="none", fx="none", mf="none", b=false, i=false, u=false, s=false, gn="", status="online"}
	if type(meta) ~= "string" then return t end
	for k, v in meta:gmatch("(%w+)=([^;]+)") do
		if k == "bs" then t.bs = v
		elseif k == "fx" then t.fx = v
		elseif k == "mf" then t.mf = v
		elseif k == "b" then t.b = (v == "1")
		elseif k == "i" then t.i = (v == "1")
		elseif k == "u" then t.u = (v == "1")
		elseif k == "s" then t.s = (v == "1")
		elseif k == "gn" then t.gn = v:gsub("_", " ")
		elseif k == "status" then t.status = v end
	end
	return t
end

local function sendPayload(textData)
	if not req then
		showNotification("Ошибка HTTP", "Экзекутор не поддерживает request", "⚠️")
		return
	end

	local bodyTable = {
		name = tostring(LP.Name),
		text = tostring(textData or ""),
		color = rgbString(col),
		meta = packMeta(),
		channel = tostring(activeChannel or "global")
	}
	if sessionToken then bodyTable.token = tostring(sessionToken) end
	if replyTo then bodyTable.reply_to = replyTo.id end

	local okJson, body = pcall(HTTP.JSONEncode, HTTP, bodyTable)
	if not okJson then
		warn("[NeonChat] JSON encode error:", body)
		showNotification("Ошибка JSON", "Не удалось подготовить сообщение", "⚠️")
		return
	end

	pendingLocal[LP.Name .. "|" .. tostring(textData)] = tick()

	task.spawn(function()
		local ok, res = pcall(req, {
			Url = API_URL .. "/send",
			Method = "POST",
			Headers = DEFAULT_HEADERS,
			Body = body
		})
		if ok and res and res.StatusCode == 200 then
			local ok2, data = pcall(HTTP.JSONDecode, HTTP, res.Body)
			if ok2 and data and data.id then myIds[data.id] = true end
		elseif ok and res and res.StatusCode == 429 then
			showNotification("Слишком быстро", "Подожди секунду", "⏱️")
		else
			showNotification("Ошибка отправки", "Сервер недоступен", "⚠️")
		end
	end)
end

local function sendTyping()
	if tick() - typingSent < 3 then return end
	typingSent = tick()
	pcall(function()
		if req and activeChannel ~= "local" then
			req({Url = API_URL .. "/typing", Method = "POST", Headers = DEFAULT_HEADERS,
				Body = HTTP:JSONEncode({name = LP.Name, channel = activeChannel, token = sessionToken or ""})})
		end
	end)
end

--// ===================== SEND HANDLERS =====================
local function sendMessage()
	local text = IB.Text
	if text:gsub("%s", "") == "" then return end
	IB.Text = ""

	if not checkCooldown(text) then IB.Text = text; return end

	drawMessage(LP.Name, text, col, bStyle, fx, msgFx, isB, isI, isU, isS, myGameName, activeChannel, nil, replyTo)

	if activeChannel == "local" then
		local NeonRemote = ReplicatedStorage:FindFirstChild("NeonRemote")
		if NeonRemote then
			pcall(function() NeonRemote:FireServer("LocalMessage", {text = text, color = rgbString(col), meta = packMeta(), reply_to = replyTo}) end)
		else
			showNotification("Ошибка сервера", "Локальный чат недоступен", "⚠️")
		end
	else
		sendPayload(text)
	end

	replyTo = nil
	TS:Create(ReplyBanner, tweenFast, {Size = UDim2.new(1, -24, 0, 0)}):Play()
	task.delay(0.25, function() ReplyBanner.Visible = false end)
end

local function sendPM(payload)
	if not activeDM then showNotification("ЛС", "Сначала выбери игрока слева", "💬"); return end
	payload = tostring(payload or "")
	if payload:gsub("%s", "") == "" then return end

	local target = safeName(activeDM)
