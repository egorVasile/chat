local function updateColorWheel(i)
    local cx = CW.AbsolutePosition.X + CW.AbsoluteSize.X / 2
    local cy = CW.AbsolutePosition.Y + CW.AbsoluteSize.Y / 2
    local dx, dy = i.Position.X - cx, i.Position.Y - cy
    -- [FIX] в оригинале было math.sqrt(dxdx+dydy) — потерялись знаки умножения, код падал
    local dist = math.sqrt(dx * dx + dy * dy)
    if dist <= 40 then
        dot.Position = UDim2.new(0, dx + 40, 0, dy + 40)
        -- [FIX] math.atan2 устарел в Luau, заменён на math.atan(y, x)
        local hue = math.atan(dy, dx) / (math.pi * 2)
        if hue < 0 then hue = hue + 1 end
        local sat = math.clamp(dist / 40, 0, 1)
        col = Color3.fromHSV(hue, sat, 1)
        prv.BackgroundColor3 = col
        MBStroke.Color = col -- [NEW] цвет кнопки обновляется сразу
        MB.TextColor3 = col
        HT.TextColor3 = col
        RS.ImageColor3 = col
    end
end

