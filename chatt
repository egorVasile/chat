--// ===================== DRAGGING & RESIZE =====================
local function makeDraggable(t, h)
	local drag, startPos, dragStart = false, nil, nil
	h.InputBegan:Connect(function(input)
		if isPress(input) then
			drag, dragStart, startPos = true, input.Position, t.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then drag = false end
			end)
		end
	end)
	Services.UIS.InputChanged:Connect(function(input)
		if drag and isMove(input) then
			local delta = input.Position - dragStart
			t.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
end
makeDraggable(UI.MB, UI.MB)
makeDraggable(UI.MF, UI.HD)
makeDraggable(UI.Island, UI.Island)

