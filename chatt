local function pollPMRequests()
	while UI.SG.Parent do
		pcall(function()
			if req then
				local ok, res = pcall(req, {Url = API_URL .. "/pm/requests?name=" .. LP.Name .. "&direction=incoming", Method = "GET", Headers = GET_HEADERS})
				if ok and res and res.StatusCode == 200 then
					local ok2, list = pcall(function() return Services.HTTP:JSONDecode(res.Body) end)
					if ok2 and type(list) == "table" then
						for _, r in ipairs(list) do
							local sender = safeName(r.from)
							if State.pmRequests[sender] ~= "pending" then
								State.pmRequests[sender] = "pending"
								if not State.shownRequestNotifications[sender] then
									State.shownRequestNotifications[sender] = true
									showNotification("Заявка на ЛС", sender .. " хочет написать", "📥")
								end
							end
						end
						refreshPMRequestsUI()
					end
				end
			end
		end)
		task.wait(5)
	end
end
