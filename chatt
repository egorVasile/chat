local function ensureDM(name)
	name = safeName(name)
	dmHistory[name] = dmHistory[name] or {}
	dmUnread[name] = dmUnread[name] or 0
	return name
end

local function clearPMMessages()
	for _, c in ipairs(PMMessages:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
end

local function drawPMBubble(sender, payload, color, isMine)
	if type(color) == "string" then color = parseColor(color) end

	local wrap = Instance.new("Frame", PMMessages)
	wrap.BackgroundTransparency = 1
	wrap.Size = UDim2.new(1, 0, 0, 34)

	local bubble = Instance.new("Frame", wrap)
	bubble.BackgroundColor3 = isMine and Color3.fromRGB(0, 150, 125) or Color3.fromRGB(32, 32, 44)
	bubble.BackgroundTransparency = 0.05
	bubble.AnchorPoint = isMine and Vector2.new(1, 0) or Vector2.new(0, 0)
	bubble.Position = isMine and UDim2.new(1, -6, 0, 0) or UDim2.new(0, 6, 0, 0)
	bubble.Size = UDim2.new(0.72, 0, 0, 34)
	bubble.ClipsDescendants = true
	Instance.new("UICorner", bubble).CornerRadius = UDim.new(0, 10)

	local nameLabel = Instance.new("TextLabel", bubble)
	nameLabel.Size = UDim2.new(1, -14, 0, 16)
	nameLabel.Position = UDim2.new(0, 7, 0, 3)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = isMine and "Вы" or sender
	nameLabel.TextColor3 = isMine and Color3.new(1, 1, 1) or color
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextSize = 11
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left

	local gifId = isGifText(payload)
	if gifId then
		local img = Instance.new("ImageLabel", bubble)
		img.Size = UDim2.new(0, 95, 0, 95)
		img.Position = UDim2.new(0, 8, 0, 21)
		img.BackgroundTransparency = 1
		img.Image = "rbxassetid://" .. gifId
		img.ScaleType = Enum.ScaleType.Fit
		bubble.Size = UDim2.new(0.42, 0, 0, 124)
		wrap.Size = UDim2.new(1, 0, 0, 126)

		task.spawn(function()
			local resolved = resolveImageId(gifId)
			if img and img.Parent then img.Image = "rbxassetid://" .. resolved end
		end)
	else
		local txt = Instance.new("TextLabel", bubble)
		txt.Size = UDim2.new(1, -14, 0, 18)
		txt.Position = UDim2.new(0, 7, 0, 19)
		txt.BackgroundTransparency = 1
		txt.Text = escapeRich(payload)
		txt.RichText = true
		txt.TextColor3 = Color3.fromRGB(245, 245, 255)
		txt.Font = Enum.Font.Gotham
		txt.TextSize = 13
		txt.TextWrapped = true
		txt.TextXAlignment = Enum.TextXAlignment.Left
		txt.TextYAlignment = Enum.TextYAlignment.Top
		task.defer(function()
			if not txt.Parent then return end
			local h = math.max(38, txt.TextBounds.Y + 28)
			bubble.Size = UDim2.new(0.72, 0, 0, h)
			wrap.Size = UDim2.new(1, 0, 0, h + 2)
		end)
	end

	bubble.Position = bubble.Position + UDim2.new(0, isMine and 30 or -30, 0, 0)
	bubble.BackgroundTransparency = 1
	TS:Create(bubble, tweenSoft, {BackgroundTransparency = 0.05, Position = isMine and UDim2.new(1, -6, 0, 0) or UDim2.new(0, 6, 0, 0)}):Play()
end

local function refreshDMList()
	for _, c in ipairs(PMList:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
	local names = {}
	for name in pairs(dmHistory) do table.insert(names, name) end
	table.sort(names)
	for _, name in ipairs(names) do
		local b = Instance.new("TextButton", PMList)
		b.Size = UDim2.new(1, -10, 0, 34)
		b.BackgroundColor3 = (activeDM == name) and col or Color3.fromRGB(28, 28, 38)
		b.BackgroundTransparency = (activeDM == name) and 0.05 or 0.2
		b.TextColor3 = (activeDM == name) and Color3.new(0, 0, 0) or Color3.new(1, 1, 1)
		b.Font = Enum.Font.GothamBold
		b.TextSize = 12
		b.TextXAlignment = Enum.TextXAlignment.Left
		b.Text = "   " .. name .. ((dmUnread[name] and dmUnread[name] > 0) and ("  (" .. dmUnread[name] .. ")") or "")
		b.ZIndex = 24
		b.AutoButtonColor = false
		Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)

		b.MouseButton1Click:Connect(function()
			activeDM, dmUnread[name] = name, 0
			updateBadge()
			refreshDMList()
			clearPMMessages()
			PMHeader.Text = "ЛС с " .. name
			for _, msg in ipairs(dmHistory[name] or {}) do
				drawPMBubble(msg.from, msg.text, msg.color or col, msg.from == LP.Name)
			end
		end)
	end
end

local function openDMWith(name)
	name = ensureDM(name)
	activeDM, dmUnread[name] = name, 0
	updateBadge()
	refreshDMList()
	clearPMMessages()
	PMHeader.Text = "ЛС с " .. name
	for _, msg in ipairs(dmHistory[name] or {}) do
		drawPMBubble(msg.from, msg.text, msg.color or col, msg.from == LP.Name)
	end
	openIsland()
end

local function handleIncoming(m)
	local target, payload = parsePMText(m.text)
	if not target then return end
	if target:lower() ~= LP.Name:lower() then return end

	local sender = safeName(m.name)
	local senderColor = rgbString(parseColor(m.color))
	ensureDM(sender)
	table.insert(dmHistory[sender], {from = sender, text = payload, color = senderColor})
	if #dmHistory[sender] > MAX_PM_MESSAGES then table.remove(dmHistory[sender], 1) end
	saveJSON("dms", dmHistory)

	if activeDM == sender then
		drawPMBubble(sender, payload, senderColor, false)
	else
		dmUnread[sender] = (dmUnread[sender] or 0) + 1
		updateBadge()
		showNotification("Новое ЛС", "От " .. sender, "💬")
	end
	refreshDMList()
end

