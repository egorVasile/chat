--// ===================== SEND HANDLERS =====================
local function sendMessage()
	local text = UI.IB.Text
	if text:gsub("%s", "") == "" then return end
	UI.IB.Text = ""

	if not checkCooldown(text) then UI.IB.Text = text; return end

	drawMessage(LP.Name, text, State.col, State.bStyle, State.fx, State.msgFx, State.isB, State.isI, State.isU, State.isS, State.myGameName, State.activeChannel, nil, State.replyTo)

	sendPayload(text)

	State.replyTo = nil
	Services.TS:Create(UI.ReplyBanner, Tween.Fast, {Size = UDim2.new(1, -24, 0, 0)}):Play()
	task.delay(0.25, function() UI.ReplyBanner.Visible = false end)
end

local function sendPM(payload)
	if not State.activeDM then showNotification("ЛС", "Сначала выбери игрока слева", "💬"); return end
	payload = tostring(payload or "")
	if payload:gsub("%s", "") == "" then return end

	local target = safeName(State.activeDM)
	local status = State.pmRequests[target]
	if status and status ~= "accepted" then
		showNotification("ЛС", "Заявка ещё не принята. Это сообщение не будет доставлено.", "⚠️")
		return
	end

	ensureDM(target)
	table.insert(State.dmHistory[target], {from = LP.Name, text = payload, color = rgbString(State.col)})
	if #State.dmHistory[target] > MAX_PM_MESSAGES then table.remove(State.dmHistory[target], 1) end

	drawPMBubble(LP.Name, payload, State.col, true)
	refreshDMList()
	sendPayload(makePMText(target, payload))
	saveJSON("dms", State.dmHistory)
end

