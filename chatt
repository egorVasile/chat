local wheelDown = false
local function updateColorWheel(input)
	local cx, cy = UI.CW.AbsolutePosition.X + UI.CW.AbsoluteSize.X/2, UI.CW.AbsolutePosition.Y + UI.CW.AbsoluteSize.Y/2
	local dx, dy = input.Position.X - cx, input.Position.Y - cy
	local dist, maxR = math.sqrt(dx*dx + dy*dy), 50
	if dist > maxR then dx, dy, dist = (dx/dist)*maxR, (dy/dist)*maxR, maxR end
	UI.ColorDot.Position = UDim2.new(0, dx + maxR, 0, dy + maxR)
	local hue = math.atan(dy, dx) / (math.pi * 2)
	if hue < 0 then hue = hue + 1 end
	State.col = Color3.fromHSV(hue, clamp(dist/maxR, 0, 1), 1)
	UI.ColorPreview.BackgroundColor3 = State.col
	updateAccent()
	saveJSON("settings", {col = rgbString(State.col), fx = State.fx, msgFx = State.msgFx, bStyle = State.bStyle, winTrans = State.windowTransparency, bgTrans = State.bgTransparency, myStatus = State.myStatus})
end

UI.CW.InputBegan:Connect(function(input) if isPress(input) then wheelDown = true updateColorWheel(input) end end)
Services.UIS.InputChanged:Connect(function(input) if wheelDown and isMove(input) then updateColorWheel(input) end end)
