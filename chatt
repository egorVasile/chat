local function sendMessage()
    local text = IB.Text
    if text:gsub("%s", "") == "" then return end
    IB.Text = ""
    drawMessage(LP.Name, text, col, bStyle, fx, msgFx, isB, isI, isU, myGameName)
    sendPayload(text)
end

