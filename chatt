local function sendMessage()
    local text = IB.Text
    if text:gsub("%s", "") == "" then return end
    IB.Text = ""

    if not checkCooldown(text) then return end

    drawMessage(LP.Name, text, col, bStyle, fx, msgFx, isB, isI, isU, isS, myGameName, activeChannel)

    if activeChannel == "local" then
        local NeonRemote = ReplicatedStorage:FindFirstChild("NeonRemote")
        if NeonRemote then
            pcall(function()
                NeonRemote:FireServer("LocalMessage", {
                    text = text,
                    color = rgbString(col),
                    meta = packMeta()
                })
            end)
        else
            showNotification("Ошибка сервера", "Локальный чат недоступен. Проверь ServerScript.")
        end
    else
        sendPayload(text)
    end
end

local function sendPM(payload)
    if not activeDM then
        showNotification("ЛС", "Сначала выбери игрока слева")
        return
    end
    payload = tostring(payload or "")
    if payload:gsub("%s", "") == "" then return end

    local target = safeName(activeDM)
    ensureDM(target)
    table.insert(dmHistory[target], {from = LP.Name, text = payload, color = rgbString(col)})
    if #dmHistory[target] > MAX_PM_MESSAGES then table.remove(dmHistory[target], 1) end

    drawPMBubble(LP.Name, payload, col, true)
    refreshDMList()
    sendPayload(makePMText(target, payload))
    saveDMs()
end

