    end)

    if mStyleFx == "glch" then
        task.spawn(function()
            while tl.Parent do
                local sqs = {}
                for _ = 1, math.random(1, 3) do
                    local sq = Instance.new("Frame", tl)
                    sq.BorderSizePixel = 0
                    sq.BackgroundColor3 = math.random() < 0.5 and Color3.fromRGB(170, 0, 255) or Color3.new(0, 0, 0)
                    sq.Size = UDim2.new(0, math.random(4, 10), 0, math.random(4, 10))
                    sq.Position = UDim2.new(0, math.random(0, math.max(1, math.floor(tl.TextBounds.X))), 0, math.random(0, 15))
                    table.insert(sqs, sq)
                end
                task.wait(math.random(5, 15) / 100)
                for _, q in ipairs(sqs) do q:Destroy() end
                task.wait(math.random(5, 20) / 100)
            end
        end)
    elseif mStyleFx == "shk" then
