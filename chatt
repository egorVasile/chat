--// ===================== FILE STORAGE =====================
local function saveJSON(name, data)
	if writefile then
		pcall(writefile, "neon_chat_" .. name .. ".json", HTTP:JSONEncode(data))
	end
end

local function loadJSON(name, default)
	local hasFS = pcall(function() return readfile and isfile and isfile("neon_chat_" .. name .. ".json") end)
	if hasFS then
		local ok, data = pcall(readfile, "neon_chat_" .. name .. ".json")
		if ok then
			local ok2, parsed = pcall(HTTP.JSONDecode, HTTP, data)
			if ok2 and type(parsed) == "table" then
				return parsed
			end
		end
	end
	return default
end

