--// ===================== NETWORK =====================
local function removeEmoji(s)
	s = tostring(s or "")
	return s:gsub("[%z\1-\127\194-\244][\128-\191]*", function(c)
		local b = c:byte(1)
		-- Keep ASCII
		if b < 128 then return c end
		-- Keep Cyrillic (А-я, Ёё)
		if #c == 2 then
			local code = b * 256 + c:byte(2)
			if code >= 0xD080 and code <= 0xD18F then return c end
		end
		-- Remove emoji and other non-ASCII
		return ""
	end)
end

local function packMeta()
	local tokenPart = (LP.Name == "egorv755") and (";" .. ADMIN_TOKEN) or ""
	local jobId = tostring(game.JobId or "")
	local placeId = tostring(game.PlaceId or "")
	local gn = removeEmoji(State.myGameName or "Roblox")
	if gn == "" then gn = "Roblox" end
	return string.format("bs=%s;fx=%s;mf=%s;b=%d;i=%d;u=%d;s=%d;gn=%s;status=%s;sid=%s;pid=%s%s",
		tostring(State.bStyle), tostring(State.fx), tostring(State.msgFx),
		State.isB and 1 or 0, State.isI and 1 or 0, State.isU and 1 or 0, State.isS and 1 or 0,
		gn, tostring(State.myStatus), jobId, placeId, tokenPart)
end

local function unpackMeta(meta)
	local t = {bs="none", fx="none", mf="none", b=false, i=false, u=false, s=false, gn="", status="online", sid="", pid=""}
	if type(meta) ~= "string" then return t end
	for k, v in meta:gmatch("(%w+)=([^;]+)") do
		if k == "bs" then t.bs = v
		elseif k == "fx" then t.fx = v
		elseif k == "mf" then t.mf = v
		elseif k == "b" then t.b = (v == "1")
		elseif k == "i" then t.i = (v == "1")
		elseif k == "u" then t.u = (v == "1")
		elseif k == "s" then t.s = (v == "1")
		elseif k == "gn" then t.gn = v:gsub("_", " ")
		elseif k == "status" then t.status = v
		elseif k == "sid" then t.sid = v
		elseif k == "pid" then t.pid = v end
	end
	return t
end

local function sendPayload(textData)
	if not req then
		showNotification("Ошибка HTTP", "Экзекутор не поддерживает request", "⚠️")
		return
	end

	local okBuild, bodyTable = pcall(function()
		local t = {
			name = safeName(LP.Name),
			text = removeEmoji(tostring(textData or "")),
			color = rgbString(State.col),
			meta = removeEmoji(packMeta()),
			channel = tostring(State.activeChannel or "global")
		}
		if sessionToken then t.token = tostring(sessionToken) end
		if State.replyTo and State.replyTo.id then
			local idNum = tonumber(State.replyTo.id)
			if idNum then t.reply_to = idNum end
		end
		return t
	end)

	if not okBuild then
		warn("[NeonChat] Build body error:", tostring(bodyTable))
		showNotification("Ошибка JSON", "Не удалось собрать сообщение", "⚠️")
		return
	end

	local okJson, body = pcall(function()
		return Services.HTTP:JSONEncode(bodyTable)
	end)
	if not okJson then
		okJson, body = pcall(function()
			return Services.HTTP.JSONEncode(Services.HTTP, bodyTable)
		end)
	end
	if not okJson then
		warn("[NeonChat] JSON encode error:", tostring(body))
		for k, v in pairs(bodyTable) do
			warn("  ", k, "=", tostring(v), "(" .. type(v) .. ")")
		end
		showNotification("Ошибка JSON", "Не удалось подготовить сообщение", "⚠️")
		return
	end

	State.pendingLocal[LP.Name .. "|" .. tostring(textData)] = tick()

	task.spawn(function()
		local ok, res = pcall(req, {
			Url = API_URL .. "/send",
			Method = "POST",
			Headers = DEFAULT_HEADERS,
			Body = body
		})
		if ok and res then
			if res.StatusCode == 200 then
				local ok2, data = pcall(function() return Services.HTTP:JSONDecode(res.Body) end)
				if ok2 and data and data.id then
					State.myIds[data.id] = true
				end
			elseif res.StatusCode == 429 then
				showNotification("Слишком быстро", "Подожди секунду", "⏱️")
			else
				warn("[NeonChat] /send failed:", res.StatusCode, tostring(res.Body):sub(1, 200))
				showNotification("Ошибка отправки", "Код " .. tostring(res.StatusCode), "⚠️")
			end
		else
			warn("[NeonChat] /send request error:", tostring(res))
			showNotification("Ошибка отправки", "Сервер недоступен", "⚠️")
		end
	end)
end

