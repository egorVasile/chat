		task.delay(0.3, function()
			SettingsGroup.Visible = false
			GF.Visible = false
			CL.Visible = true
			ChannelsPanel.Visible = true
			BB.Visible = true
			TS:Create(CL, tweenSmooth, {Position = UDim2.new(0, 12, 0, 54)}):Play()
			TS:Create(ChannelsPanel, tweenSmooth, {Position = UDim2.new(1, -122, 0, 50)}):Play()
