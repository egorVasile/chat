end)

-- ===================== ПЕРЕТАСКИВАНИЕ =====================
local function makeDraggable(target, handle)
    local dragging, dragInput, dragStart, startPos, moved = false, nil, nil, nil, false
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging, moved = true, false
            dragStart, startPos = i.Position, target.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
            dragInput = i
        end
    end)
    UIS.InputChanged:Connect(function(i)
        if i == dragInput and dragging then
            local d = i.Position - dragStart
            if d.Magnitude > 5 then moved = true end
            target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
    return function() return moved end
end

local buttonMoved = makeDraggable(MB, MB)
makeDraggable(MF, HD)

-- ===================== РЕСАЙЗ =====================
local resizing, resizeStart, startSize = false, nil, nil
RS.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        resizing, resizeStart, startSize = true, i.Position, MF.Size
    end
end)
UIS.InputChanged:Connect(function(i)
    if resizing and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
        local d = i.Position - resizeStart
        local nW = math.clamp(startSize.X.Offset + d.X, 320, 700)
        local nH = math.clamp(startSize.Y.Offset + d.Y, 250, 600)
        MF.Size = UDim2.new(0, nW, 0, nH)
    end
end)
UIS.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        resizing = false
    end
end)

-- ===================== ОТКРЫТИЕ / ЗАКРЫТИЕ =====================
local chatOpen = false
local lastSize = UDim2.new(0, 440, 0, 260) -- [NEW] запоминает размер после ресайза

local function toggleChat()
    chatOpen = not chatOpen
    if chatOpen then
        MF.Visible = true
        MF.Size = UDim2.new(0, 0, 0, 0)
        MF.BackgroundTransparency = 1
        TS:Create(MF, TweenInfo.new(0.35, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
            Size = lastSize,
            BackgroundTransparency = 0.25,
        }):Play()
    else
        lastSize = MF.Size -- [FIX] раньше после закрытия окно всегда сбрасывалось на 440x260
        local ct = TS:Create(MF, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 1,
        })
        ct:Play()
        ct.Completed:Connect(function()
            if not chatOpen then MF.Visible = false end
        end)
    end
end

MB.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        MB:TweenSize(UDim2.new(0, 52, 0, 52), "Out", "Quad", 0.1, true)
        local conn
        conn = i.Changed:Connect(function()
            if i.UserInputState == Enum.UserInputState.End then
                conn:Disconnect()
                MB:TweenSize(UDim2.new(0, 60, 0, 60), "Out", "Quad", 0.1, true)
                if not buttonMoved() then
                    toggleChat()
                end
            end
        end)
    end
end)

